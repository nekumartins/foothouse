# Sanity CMS — create a project at sanity.io, then fill these in
# Manages writing, projects, the now-cards, AND map places.
SANITY_PROJECT_ID=your-sanity-project-id
SANITY_DATASET=production

# Supabase — optional fallback for map places if Sanity is not configured
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Optional: RSS feed for the "lately" card's latest post.
# X killed its free API — create a feed from your profile at rss.app (or any
# RSS bridge / Nitter instance) and paste the feed URL here.
# LATELY_RSS_URL=https://rss.app/feeds/xxxxxxxx.xml

# Optional: GitHub token for star counts and building text (avoids rate limits)
# GITHUB_TOKEN=ghp_your_token
# GITHUB_PINNED_REPO=nekumartins/debate-coach

# Optional: Spotify integration for live listening card
# SPOTIFY_CLIENT_ID=your_client_id
# SPOTIFY_CLIENT_SECRET=your_client_secret
# SPOTIFY_REFRESH_TOKEN=your_refresh_token
