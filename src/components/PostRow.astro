---
import { postPath } from '../lib/posts';

interface Props {
  post: {
    slug: string;
    title: string;
    excerpt?: string;
    canonical: string;
    medium_url?: string;
    reading_min?: number;
    series?: { slug: string } | null;
  };
  seriesSlug?: string;
}

const { post, seriesSlug } = Astro.props;
const { href, external: isLinkOut } = postPath(post, seriesSlug);
---

<a
  href={href}
  class:list={['post-row', { 'post-row--linkout': isLinkOut }]}
  {...(isLinkOut ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <div class="post-row__content">
    <h3 class="post-row__title">{post.title}</h3>
    {post.excerpt && <p class="post-row__excerpt">{post.excerpt}</p>}
  </div>
  <div class="post-row__meta">
    {post.reading_min && <span class="post-row__time">{post.reading_min} min</span>}
    {isLinkOut && (
      <svg class="post-row__external" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-label="Opens on Medium">
        <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </div>
</a>

<style>
  .post-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--tint-edge);
    text-decoration: none;
    transition: border-color var(--t-fast) ease;
  }

  .post-row:first-child {
    border-top: 1px solid var(--tint-edge);
  }

  .post-row:hover {
    border-color: color-mix(in srgb, var(--ink-accent) 25%, transparent);
  }

  .post-row__content {
    flex: 1;
    min-width: 0;
  }

  .post-row__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
    transition: color var(--t-fast) ease;
  }

  .post-row:hover .post-row__title {
    color: var(--ink-accent);
  }

  .post-row__excerpt {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .post-row__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
    padding-top: 0.2em;
  }

  .post-row__time {
    font-size: var(--text-xs);
    color: var(--ink-muted);
    white-space: nowrap;
  }

  .post-row__external {
    color: var(--ink-faint);
    flex-shrink: 0;
    opacity: 0;
    transition: opacity var(--t-fast) ease, color var(--t-fast) ease, transform var(--t-fast) ease;
  }

  .post-row:hover .post-row__external {
    opacity: 1;
    color: var(--ink-accent);
    transform: translate(1px, -1px);
  }
</style>
