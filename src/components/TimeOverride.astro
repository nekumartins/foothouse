---
// Quiet corner control to scrub through the day. A sun/moon icon opens a
// slider; a always-visible minimize button collapses the whole thing to a
// small dim dot, which restores it on click.
---

<div class="time-override" id="time-override">
  <div class="time-override__bar">
    <button
      class="time-override__toggle"
      id="time-toggle"
      aria-label="Adjust sky time of day"
      title="Change time of day"
    >
      <svg class="time-override__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <g id="time-icon-sun">
          <circle cx="12" cy="12" r="4" />
          <line x1="12" y1="2" x2="12" y2="5" />
          <line x1="12" y1="19" x2="12" y2="22" />
          <line x1="2" y1="12" x2="5" y2="12" />
          <line x1="19" y1="12" x2="22" y2="12" />
          <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" />
          <line x1="16.95" y1="16.95" x2="19.07" y2="19.07" />
          <line x1="4.93" y1="19.07" x2="7.05" y2="16.95" />
          <line x1="16.95" y1="7.05" x2="19.07" y2="4.93" />
        </g>
        <path id="time-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" style="display:none" />
      </svg>
    </button>

    <button
      class="time-override__minimize"
      id="time-minimize"
      aria-label="Minimize time control"
      title="Minimize"
    >
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <line x1="4" y1="8" x2="12" y2="8" />
      </svg>
    </button>
  </div>

  <div class="time-override__panel" id="time-panel" hidden>
    <input
      type="range"
      id="time-slider"
      min="0"
      max="23"
      step="1"
      class="time-override__slider"
      aria-label="Hour of day"
    />
    <span class="time-override__label" id="time-label">12:00</span>
    <button class="time-override__reset" id="time-reset" aria-label="Reset to real time">
      Reset
    </button>
  </div>
</div>

<!-- Restore nub, shown only while minimized -->
<button
  class="time-override__restore"
  id="time-restore"
  hidden
  aria-label="Restore time control"
  title="Time of day"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" id="restore-icon">
    <!-- Sun (day) -->
    <g id="restore-sun">
      <circle cx="12" cy="12" r="3.5" />
      <line x1="12" y1="3" x2="12" y2="5.5" />
      <line x1="12" y1="18.5" x2="12" y2="21" />
      <line x1="3" y1="12" x2="5.5" y2="12" />
      <line x1="18.5" y1="12" x2="21" y2="12" />
      <line x1="5.64" y1="5.64" x2="7.4" y2="7.4" />
      <line x1="16.6" y1="16.6" x2="18.36" y2="18.36" />
      <line x1="5.64" y1="18.36" x2="7.4" y2="16.6" />
      <line x1="16.6" y1="7.4" x2="18.36" y2="5.64" />
    </g>
    <!-- Moon (night) -->
    <path id="restore-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" style="display:none" />
  </svg>
</button>

<script>
  import { setOverrideHour, getOverrideHour } from '../scripts/sky';

  const container = document.getElementById('time-override')!;
  const toggle = document.getElementById('time-toggle')!;
  const panel = document.getElementById('time-panel')!;
  const slider = document.getElementById('time-slider') as HTMLInputElement;
  const label = document.getElementById('time-label')!;
  const reset = document.getElementById('time-reset')!;
  const minimize = document.getElementById('time-minimize')!;
  const restore = document.getElementById('time-restore')!;
  const iconSun = document.getElementById('time-icon-sun')!;
  const iconMoon = document.getElementById('time-icon-moon')!;
  const restoreSun = document.getElementById('restore-sun')!;
  const restoreMoon = document.getElementById('restore-moon')!;

  const minimizedKey = 'foothouse-time-minimized';

  function setMinimized(min: boolean) {
    container.hidden = min;
    restore.hidden = !min;
    if (min) {
      panel.hidden = true;
      sessionStorage.setItem(minimizedKey, '1');
    } else {
      sessionStorage.setItem(minimizedKey, '0');
    }
  }

  function updateIcon(hour: number) {
    const isNight = hour >= 19 || hour < 5;
    iconSun.style.display = isNight ? '' : 'none';
    iconMoon.style.display = isNight ? 'none' : '';
    restoreSun.style.display = isNight ? '' : 'none';
    restoreMoon.style.display = isNight ? 'none' : '';
  }

  function formatHour(h: number): string {
    const period = h >= 12 ? 'PM' : 'AM';
    const display = h === 0 ? 12 : h > 12 ? h - 12 : h;
    return `${display}:00 ${period}`;
  }

  toggle.addEventListener('click', () => {
    const isHidden = panel.hidden;
    panel.hidden = !isHidden;
    if (isHidden) {
      const current = getOverrideHour() ?? new Date().getHours();
      slider.value = String(current);
      label.textContent = formatHour(current);
      updateIcon(current);
    }
  });

  slider.addEventListener('input', () => {
    const hour = parseInt(slider.value, 10);
    label.textContent = formatHour(hour);
    setOverrideHour(hour);
    updateIcon(hour);
  });

  reset.addEventListener('click', () => {
    setOverrideHour(null);
    const hour = new Date().getHours();
    slider.value = String(hour);
    label.textContent = formatHour(hour);
    updateIcon(hour);
  });

  minimize.addEventListener('click', () => setMinimized(true));
  restore.addEventListener('click', () => setMinimized(false));

  const currentHour = getOverrideHour() ?? new Date().getHours();
  updateIcon(currentHour);
  // Default to the collapsed nub; only stay expanded if the user explicitly opened it.
  setMinimized(sessionStorage.getItem(minimizedKey) !== '0');

  // Keep the icon in sync as the sky updates every minute
  window.addEventListener('sky-update', (e: any) => {
    updateIcon(e.detail.hour);
  });
</script>

<style>
  .time-override {
    position: fixed;
    bottom: var(--space-lg);
    right: var(--space-lg);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-sm);
  }

  .time-override[hidden] {
    display: none;
  }

  .time-override__bar {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .time-override__toggle,
  .time-override__minimize {
    border: 1px solid var(--line);
    border-radius: 50%;
    background: rgba(30, 24, 19, 0.6);
    backdrop-filter: blur(8px);
    color: var(--muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .time-override__toggle {
    width: 36px;
    height: 36px;
  }

  .time-override__minimize {
    width: 26px;
    height: 26px;
    color: var(--faint);
  }

  .time-override__toggle:hover,
  .time-override__minimize:hover {
    color: var(--lamp);
    border-color: var(--lamp);
  }

  .time-override__icon {
    width: 18px;
    height: 18px;
  }

  .time-override__minimize svg {
    width: 14px;
    height: 14px;
  }

  .time-override__panel {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: rgba(30, 24, 19, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid var(--line);
    border-radius: 20px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .time-override__slider {
    width: 120px;
    accent-color: var(--lamp);
    cursor: pointer;
  }

  .time-override__label {
    font-size: var(--text-xs);
    color: var(--muted);
    min-width: 65px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  .time-override__reset {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--faint);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    transition: color 0.2s ease;
  }

  .time-override__reset:hover {
    color: var(--paper);
  }

  .time-override__restore {
    position: fixed;
    bottom: var(--space-lg);
    right: var(--space-lg);
    z-index: 100;
    width: 32px;
    height: 32px;
    border: 1px solid color-mix(in srgb, var(--lamp) 45%, transparent);
    border-radius: 50%;
    background: rgba(30, 24, 19, 0.55);
    color: var(--lamp);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 0.85;
    box-shadow: 0 0 10px color-mix(in srgb, var(--lamp) 40%, transparent),
                0 0 22px color-mix(in srgb, var(--lamp) 18%, transparent);
    animation: nub-pulse 3s ease-in-out infinite;
    transition: opacity 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  @keyframes nub-pulse {
    0%, 100% {
      box-shadow: 0 0 8px color-mix(in srgb, var(--lamp) 30%, transparent),
                  0 0 16px color-mix(in srgb, var(--lamp) 12%, transparent);
    }
    50% {
      box-shadow: 0 0 14px color-mix(in srgb, var(--lamp) 55%, transparent),
                  0 0 30px color-mix(in srgb, var(--lamp) 28%, transparent);
    }
  }

  .time-override__restore[hidden] {
    display: none;
  }

  .time-override__restore:hover {
    opacity: 1;
    color: var(--lamp);
    border-color: var(--lamp);
  }

  @media (prefers-reduced-motion: reduce) {
    .time-override__restore {
      animation: none;
    }
  }

  .time-override__restore svg {
    width: 16px;
    height: 16px;
  }

  @media (prefers-reduced-motion: reduce) {
    .time-override__panel {
      animation: none;
    }
  }
</style>
