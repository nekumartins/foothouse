---
interface Props {
  project: {
    name: string;
    tagline: string;
    repo_url?: string;
    live_url?: string;
    github_sync?: boolean;
    stars?: number;
  };
}

const { project } = Astro.props;
const href = project.live_url || project.repo_url;
---

{href ? (
  <a href={href} target="_blank" rel="noopener noreferrer" class="project-card">
    <div class="project-card__inner">
      <h3 class="project-card__name">
        {project.name}
        <svg class="project-card__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </h3>
      <p class="project-card__tagline">{project.tagline}</p>
    </div>
    {project.github_sync && project.stars != null && (
      <span class="project-card__stars">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 1l1.545 3.13L11 4.635 8.5 7.07l.59 3.43L6 8.885 2.91 10.5l.59-3.43L1 4.635l3.455-.505L6 1z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
        </svg>
        {project.stars}
      </span>
    )}
  </a>
) : (
  <div class="project-card">
    <div class="project-card__inner">
      <h3 class="project-card__name">{project.name}</h3>
      <p class="project-card__tagline">{project.tagline}</p>
    </div>
  </div>
)}

<style>
  .project-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(30, 24, 19, 0.25);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.3s ease, border-color 0.3s ease;
    margin-bottom: var(--space-md);
  }

  .project-card:hover {
    background: rgba(30, 24, 19, 0.45);
    border-color: rgba(236, 227, 214, 0.12);
  }

  .project-card__inner {
    flex: 1;
    min-width: 0;
  }

  .project-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    transition: color 0.3s ease;
  }

  .project-card:hover .project-card__name {
    color: var(--lamp);
  }

  .project-card__arrow {
    opacity: 0;
    color: var(--faint);
    flex-shrink: 0;
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover .project-card__arrow {
    opacity: 1;
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .project-card__tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.5;
  }

  .project-card__stars {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--faint);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.2em;
  }
</style>
