---
interface Props {
  project: {
    name: string;
    tagline: string;
    slug?: string;
    has_story?: boolean;
    repo_url?: string;
    live_url?: string;
    github_sync?: boolean;
    stars?: number;
  };
}

const { project } = Astro.props;
// Projects with a written case study open their own room; the rest link out.
const hasStory = Boolean(project.has_story && project.slug);
const href = hasStory ? `/work/${project.slug}` : project.live_url || project.repo_url;
const external = Boolean(href) && !hasStory;
---

{href ? (
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
    class="project-card"
  >
    <div class="project-card__inner">
      <h3 class="project-card__name">
        {project.name}
        <svg class="project-card__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </h3>
      <p class="project-card__tagline">{project.tagline}</p>
      {hasStory && <span class="project-card__story">case study</span>}
    </div>
    {project.github_sync && project.stars != null && (
      <span class="project-card__stars">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M6 1l1.545 3.13L11 4.635 8.5 7.07l.59 3.43L6 8.885 2.91 10.5l.59-3.43L1 4.635l3.455-.505L6 1z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/>
        </svg>
        {project.stars}
      </span>
    )}
  </a>
) : (
  <div class="project-card">
    <div class="project-card__inner">
      <h3 class="project-card__name">{project.name}</h3>
      <p class="project-card__tagline">{project.tagline}</p>
    </div>
  </div>
)}

<style>
  .project-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--tint);
    border: 1px solid var(--tint-edge);
    border-radius: var(--r-md);
    text-decoration: none;
    transition: background-color var(--t-med) var(--ease-out), transform var(--t-med) var(--ease-out);
    margin-bottom: var(--space-md);
  }

  .project-card:hover {
    background: color-mix(in srgb, var(--ink) 9%, transparent);
    transform: translateY(-1px);
  }

  .project-card__inner {
    flex: 1;
    min-width: 0;
  }

  .project-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    transition: color var(--t-fast) ease;
  }

  .project-card:hover .project-card__name {
    color: var(--ink-accent);
  }

  .project-card__arrow {
    opacity: 0;
    color: var(--ink-faint);
    flex-shrink: 0;
    transition: opacity var(--t-fast) ease, color var(--t-fast) ease, transform var(--t-fast) ease;
  }

  .project-card:hover .project-card__arrow {
    opacity: 1;
    color: var(--ink-accent);
    transform: translate(1px, -1px);
  }

  .project-card__tagline {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    line-height: 1.5;
  }

  .project-card__story {
    display: inline-block;
    margin-top: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  .project-card__stars {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--ink-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.2em;
  }
</style>
