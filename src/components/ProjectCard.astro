---
interface Props {
  project: {
    name: string;
    tagline: string;
    repo_url?: string;
    live_url?: string;
    github_sync?: boolean;
    stars?: number;
  };
}

const { project } = Astro.props;
const href = project.live_url || project.repo_url;
---

<div class="project-card">
  <div class="project-card__content">
    <h3 class="project-card__name">
      {href ? (
        <a href={href} target="_blank" rel="noopener noreferrer" class="project-card__link">
          {project.name}
          <span class="project-card__arrow">&#8599;</span>
        </a>
      ) : (
        project.name
      )}
    </h3>
    <p class="project-card__tagline">{project.tagline}</p>
  </div>
  {project.github_sync && project.stars != null && (
    <span class="project-card__stars" title={`${project.stars} stars on GitHub`}>
      &#9734; {project.stars}
    </span>
  )}
</div>

<style>
  .project-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--line);
  }

  .project-card:first-child {
    border-top: 1px solid var(--line);
  }

  .project-card__content {
    flex: 1;
    min-width: 0;
  }

  .project-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .project-card__link {
    color: var(--paper);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .project-card__link:hover {
    color: var(--lamp);
  }

  .project-card__arrow {
    font-size: var(--text-sm);
    color: var(--faint);
    margin-left: var(--space-xs);
  }

  .project-card__link:hover .project-card__arrow {
    color: var(--lamp);
  }

  .project-card__tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.5;
  }

  .project-card__stars {
    font-size: var(--text-xs);
    color: var(--faint);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.2em;
  }
</style>
