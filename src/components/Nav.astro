---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/writing', label: 'Writing' },
  { href: '/map', label: 'Map' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav__home" aria-label="Home">
    <img src="/avatar.png" alt="Neku" class="nav__avatar" width="32" height="32" />
  </a>
  <ul class="nav__links" role="list">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': currentPath.startsWith(link.href) }]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* A floating frosted-glass pill instead of a full-width bar, so the
     living sky stays visible around it. Background alpha is driven by
     --scrim-alpha (src/scripts/scrim.ts), computed from the live sky
     palette, so it stays subtle at night and only opaque enough to hold
     AA text contrast when the day sky is bright. */
  .nav {
    position: fixed;
    top: var(--space-md);
    left: var(--space-md);
    right: var(--space-md);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-lg);
    background: rgb(21 17 13 / var(--scrim-alpha, 0.55));
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  .nav__home {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .nav__home:hover {
    opacity: 1;
  }

  .nav__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
  }

  .nav__links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav__link {
    text-decoration: none;
    color: var(--muted);
    transition: color 0.3s ease;
    letter-spacing: 0.02em;
  }

  .nav__link:hover {
    color: var(--paper);
  }

  .nav__link--active {
    color: var(--paper);
  }

  @media (max-width: 480px) {
    .nav {
      padding: var(--space-sm) var(--space-md);
    }

    .nav__links {
      gap: var(--space-md);
    }

    .nav__link {
      font-size: var(--text-xs);
    }
  }
</style>
