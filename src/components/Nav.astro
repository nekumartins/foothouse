---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/writing', label: 'Writing' },
  { href: '/map', label: 'Map' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav__home" aria-label="Home">
    <img src="/avatar.png" alt="Neku" class="nav__avatar" width="32" height="32" />
  </a>
  <ul class="nav__links" role="list">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': currentPath.startsWith(link.href) }]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* A detached floating pill, centered, never glued edge-to-edge to
     whatever sits below it. One material with the rest of the site: the
     glass recipe, ink-relative, no scrim/opacity gymnastics. */
  .nav {
    position: fixed;
    top: max(var(--space-md), env(safe-area-inset-top));
    left: 50%;
    transform: translateX(-50%);
    width: min(var(--w-nav), calc(100vw - 2 * var(--space-md)));
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 10px 6px 6px;
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid var(--glass-edge);
    border-radius: var(--r-pill);
    box-shadow: inset 0 1px 0 var(--glass-rim);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    transition: background-color 800ms ease, border-color 800ms ease;
  }

  .nav__home {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .nav__home:hover {
    opacity: 1;
  }

  .nav__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
  }

  .nav__links {
    display: flex;
    gap: var(--space-xs);
    list-style: none;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 14px;
    color: var(--ink-muted);
    text-decoration: none;
    border-radius: var(--r-pill);
    letter-spacing: 0.02em;
    transition: color var(--t-fast) ease, background-color var(--t-fast) ease;
  }

  .nav__link:hover {
    color: var(--ink);
    background: var(--tint);
  }

  .nav__link--active {
    color: var(--ink);
    background: color-mix(in srgb, var(--ink) 10%, transparent);
  }

  @media (max-width: 480px) {
    .nav__links {
      gap: 2px;
    }

    .nav__link {
      padding: 10px 10px;
    }
  }
</style>
