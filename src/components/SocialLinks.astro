---
// Icon row for socials + contact, used by the footer and the About page.
// Brand marks (GitHub / LinkedIn / X) are filled; utility glyphs (email,
// résumé) are stroked. One source of truth for which links exist.
interface Props {
  settings?: any;
  align?: 'center' | 'start';
}
const { settings, align = 'center' } = Astro.props;

const s = {
  github: settings?.github || 'https://github.com/nekumartins',
  linkedin: settings?.linkedin || 'https://linkedin.com/in/nekumartins',
  twitter: settings?.twitter || 'https://twitter.com/nekumartins',
  email: settings?.contact_email || null,
  resume: settings?.resume_url || null,
};

const links = [
  s.email && { key: 'email', label: 'Email', href: `mailto:${s.email}`, external: false },
  s.github && { key: 'github', label: 'GitHub', href: s.github, external: true },
  s.linkedin && { key: 'linkedin', label: 'LinkedIn', href: s.linkedin, external: true },
  s.twitter && { key: 'x', label: 'X', href: s.twitter, external: true },
  s.resume && { key: 'resume', label: 'Résumé', href: s.resume, external: true },
].filter(Boolean) as { key: string; label: string; href: string; external: boolean }[];
---

<nav class:list={['social', `social--${align}`]} aria-label="Profiles and contact">
  {links.map((link) => (
    <a
      href={link.href}
      class="social__link"
      aria-label={link.label}
      title={link.label}
      target={link.external ? '_blank' : undefined}
      rel={link.external ? 'noopener noreferrer' : undefined}
    >
      {link.key === 'github' && (
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
      )}
      {link.key === 'linkedin' && (
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.75C24 .78 23.2 0 22.22 0z"/></svg>
      )}
      {link.key === 'x' && (
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      )}
      {link.key === 'email' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 5 8-5"/></svg>
      )}
      {link.key === 'resume' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 3h7l5 5v13H7z"/><path d="M14 3v5h5"/><path d="M10 13h5M10 16.5h5"/></svg>
      )}
    </a>
  ))}
</nav>

<style>
  .social {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .social--center { justify-content: center; }
  .social--start { justify-content: flex-start; }

  .social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: color 0.3s ease, transform 0.2s ease;
  }

  .social__link:hover {
    color: var(--lamp);
    transform: translateY(-1px);
  }

  .social__link svg {
    width: 20px;
    height: 20px;
    display: block;
  }
</style>
