---
const cards = [
  { label: 'listening to', text: "whatever's on, a bit too loudly" },
  { label: 'reading', text: 'The Beginning of Infinity, slowly, on purpose' },
  { label: 'building', text: 'something that bends light, currently fighting Safari' },
  { label: 'lately', text: "packing for Europe and pretending I'm ready" },
];
---

<div class="now-cards">
  {cards.map(card => (
    <div class="now-card" data-glass>
      <div class="glass-refraction" aria-hidden="true">
        <div class="glass-sky-copy"></div>
      </div>
      <div class="glass-highlight" aria-hidden="true"></div>
      <div class="glass-content">
        <span class="now-card__label">{card.label}</span>
        <span class="now-card__text">{card.text}</span>
      </div>
    </div>
  ))}
</div>

<script>
  import { initGlass } from '../scripts/glass';
  initGlass();
</script>

<style>
  .now-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 640px;
    width: 100%;
  }

  .now-card {
    position: relative;
    padding: var(--space-lg) var(--space-md);
    background: rgba(30, 24, 19, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: border-color 0.4s ease, background 0.4s ease;
    overflow: hidden;
  }

  .now-card.glass-active {
    background: rgba(30, 24, 19, 0.15);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .now-card.glass-fallback {
    background: rgba(30, 24, 19, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .now-card:hover {
    border-color: rgba(224, 164, 88, 0.15);
  }

  .now-card.glass-active:hover {
    background: rgba(30, 24, 19, 0.2);
  }

  .glass-refraction {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    z-index: 0;
    pointer-events: none;
  }

  .glass-sky-copy {
    position: absolute;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bottom) 100%
    );
    pointer-events: none;
    will-change: transform;
  }

  .glass-highlight {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.07) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      transparent 60%
    );
  }

  .glass-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .now-card__label {
    font-size: var(--text-xs);
    color: var(--faint);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .now-card__text {
    font-size: var(--text-sm);
    color: var(--paper);
    line-height: 1.5;
  }

  @media (max-width: 520px) {
    .now-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
