---
interface Props {
  now?: {
    listening_text?: string;
    reading_title?: string;
    reading_author?: string;
    building_text?: string;
    status_line?: string;
  };
}

const { now } = Astro.props;

const readingText = now?.reading_title
  ? now.reading_author
    ? `${now.reading_title} by ${now.reading_author}`
    : now.reading_title
  : 'The Beginning of Infinity, slowly, on purpose';

const listeningFallback = "whatever's on, a bit too loudly";

const cards = [
  { label: 'listening to', text: now?.listening_text ?? listeningFallback, field: 'listening' },
  { label: 'reading', text: readingText },
  { label: 'building', text: now?.building_text ?? 'something that bends light, currently fighting Safari' },
  { label: 'lately', text: now?.status_line ?? "packing for Europe and pretending I'm ready" },
];
---

<div class="now-cards">
  {cards.map(card => (
    <div class="now-card" data-glass>
      <div class="glass-refraction" aria-hidden="true">
        <div class="glass-sky-copy"></div>
      </div>
      <div class="glass-highlight" aria-hidden="true"></div>
      <div class="glass-content">
        <span class="now-card__label">{card.label}</span>
        <span class="now-card__text" data-now-field={card.field}>{card.text}</span>
      </div>
    </div>
  ))}
</div>

<script>
  import { initGlass } from '../scripts/glass';
  initGlass();

  // Keep the "listening to" card live: poll the server endpoint that reads
  // Spotify. The build-time value is the initial paint; this refreshes it.
  const FALLBACK = "whatever's on, a bit too loudly";
  const el = document.querySelector<HTMLElement>('[data-now-field="listening"]');

  async function refreshListening() {
    if (!el) return;
    try {
      const res = await fetch('/api/now-playing', { cache: 'no-store' });
      if (!res.ok) return;
      const { listening } = await res.json();
      const next = listening || FALLBACK;
      if (next !== el.textContent) el.textContent = next;
    } catch {
      // keep whatever is on screen
    }
  }

  if (el) {
    refreshListening();
    setInterval(refreshListening, 20000);
    // Refresh when the tab regains focus, not just on the timer.
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') refreshListening();
    });
  }
</script>

<style>
  .now-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: 640px;
    width: 100%;
  }

  .now-card {
    position: relative;
    padding: var(--space-lg) var(--space-md);
    background: rgba(30, 24, 19, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: border-color 0.4s ease, background 0.4s ease;
    overflow: hidden;
  }

  .now-card.glass-active {
    background: rgba(30, 24, 19, 0.15);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .now-card.glass-fallback {
    background: rgba(30, 24, 19, 0.35);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .now-card:hover {
    border-color: rgba(224, 164, 88, 0.15);
  }

  .now-card.glass-active:hover {
    background: rgba(30, 24, 19, 0.2);
  }

  .glass-refraction {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    z-index: 0;
    pointer-events: none;
  }

  .glass-sky-copy {
    position: absolute;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bottom) 100%
    );
    pointer-events: none;
    will-change: transform;
  }

  .glass-highlight {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.07) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      transparent 60%
    );
  }

  .glass-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .now-card__label {
    font-size: var(--text-xs);
    color: var(--faint);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .now-card__text {
    font-size: var(--text-sm);
    color: var(--paper);
    line-height: 1.5;
  }

  @media (max-width: 520px) {
    .now-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
