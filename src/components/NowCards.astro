---
// A slim one-line "currently" strip: what I'm listening to (live from Spotify)
// and my latest post. Every fragment hides when its data is idle/empty — no
// "Not listening to anything" filler. Listening-first.
interface Props {
  now?: {
    listening_text?: string;
    status_line?: string;
  };
}

const { now } = Astro.props;

const lately = now?.status_line || null;

// Any server-known content means the strip is visible on first paint; the
// Spotify fragment reveals itself when a live track arrives.
const hasStatic = Boolean(lately);
---

<div class="now-strip" id="now-strip" hidden={!hasStatic}>
  <span class="now-strip__item now-strip__spotify" id="now-spotify" hidden>
    <svg class="now-strip__glyph" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
    </svg>
    <span class="now-strip__eq" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="now-strip__text" id="now-track"></span>
  </span>

  {lately && (
    <span class="now-strip__item now-strip__lately">
      <svg class="now-strip__glyph now-strip__glyph--x" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span class="now-strip__text" id="now-lately">{lately}</span>
    </span>
  )}
</div>

<script>
  const strip = document.getElementById('now-strip');
  const spotifyItem = document.getElementById('now-spotify');
  const trackEl = document.getElementById('now-track');

  function revealStrip() {
    if (!strip) return;
    // Visible if any child item is not hidden.
    const anyVisible = Array.from(strip.children).some((c) => !(c as HTMLElement).hidden);
    strip.hidden = !anyVisible;
  }

  async function refreshSpotify() {
    if (!spotifyItem || !trackEl) return;
    try {
      const res = await fetch('/api/now-playing', { cache: 'no-store' });
      if (!res.ok) return;
      const data = await res.json();
      if (data && data.track && data.isPlaying) {
        trackEl.textContent = data.artist ? `${data.track} · ${data.artist}` : data.track;
        spotifyItem.hidden = false;
      } else {
        spotifyItem.hidden = true;
      }
    } catch {
      // leave whatever is currently shown
    }
    revealStrip();
  }

  refreshSpotify();
  setInterval(refreshSpotify, 15000);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') refreshSpotify();
  });

  // "Lately" upgrades to the latest tweet when available; hand-edited line stays
  // otherwise. When the tweet's URL is known, the text becomes a link to the post.
  (async () => {
    let latelyEl = document.getElementById('now-lately');
    if (!latelyEl) return;
    try {
      const res = await fetch('/api/lately', { cache: 'no-store' });
      if (!res.ok) return;
      const { text, url } = await res.json();
      if (text && text !== latelyEl.textContent) latelyEl.textContent = text;
      if (url) {
        if (latelyEl.tagName !== 'A') {
          const anchor = document.createElement('a');
          anchor.id = latelyEl.id;
          anchor.className = latelyEl.className;
          anchor.target = '_blank';
          anchor.rel = 'noopener noreferrer';
          anchor.textContent = latelyEl.textContent;
          latelyEl.replaceWith(anchor);
          latelyEl = anchor;
        }
        (latelyEl as HTMLAnchorElement).href = url;
      }
    } catch {
      // keep the server line
    }
  })();
</script>

<style>
  .now-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-md) var(--space-lg);
    max-width: 560px;
    width: 100%;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .now-strip[hidden] {
    display: none;
  }

  .now-strip__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    min-width: 0;
  }

  .now-strip__item[hidden] {
    display: none;
  }

  .now-strip__glyph {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: var(--faint);
  }

  .now-strip__spotify .now-strip__glyph {
    color: var(--lamp);
  }

  .now-strip__text {
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 40ch;
  }

  /* A tweet is the point of the lately fragment: let it wrap instead of
     chopping it mid-sentence. 52ch x 6 lines holds any single post (280
     chars); the clamp only guards pathological feed input. */
  .now-strip__lately {
    align-items: flex-start;
  }

  .now-strip__lately .now-strip__glyph {
    margin-top: 3px;
  }

  .now-strip__lately .now-strip__text {
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    max-width: 52ch;
    text-align: left;
    line-height: 1.5;
  }

  /* When the lately text is the tweet itself, it links to the post. */
  a.now-strip__text {
    text-decoration: none;
    transition: color 0.3s ease;
  }

  a.now-strip__text:hover {
    color: var(--lamp);
  }

  /* Tiny now-playing equalizer. */
  .now-strip__eq {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 12px;
  }

  .now-strip__eq i {
    width: 2px;
    background: var(--lamp);
    border-radius: 1px;
    animation: eq 900ms ease-in-out infinite;
  }

  .now-strip__eq i:nth-child(1) { height: 40%; animation-delay: -200ms; }
  .now-strip__eq i:nth-child(2) { height: 100%; animation-delay: -500ms; }
  .now-strip__eq i:nth-child(3) { height: 65%; animation-delay: 0ms; }

  @keyframes eq {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .now-strip__eq i { animation: none; height: 70%; }
  }
</style>
