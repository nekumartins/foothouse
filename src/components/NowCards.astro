---
interface Props {
  now?: {
    listening_text?: string;
    reading_title?: string;
    reading_author?: string;
    building_text?: string;
    status_line?: string;
  };
}

const { now } = Astro.props;

const readingText = now?.reading_title
  ? now.reading_author
    ? `${now.reading_title} by ${now.reading_author}`
    : now.reading_title
  : 'The Beginning of Infinity, slowly, on purpose';

const listeningText = now?.listening_text || null;

const cards = [
  { label: 'reading', text: readingText },
  { label: 'building', text: now?.building_text ?? 'something that bends light, currently fighting Safari' },
  { label: 'lately', text: now?.status_line ?? "packing for Europe and pretending I'm ready" },
];
---

<div class="now-stack">
  <!-- Spotify row -->
  <div class="glass-card glass-card--spotify">
    <div class="glass-card__content spotify">
      <svg class="spotify__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
      </svg>
      <div class="spotify__info">
        <span class="spotify__label">currently listening to</span>
        <span class="spotify__track" data-now-field="listening">
          {listeningText ?? 'Not listening to anything.'}
        </span>
      </div>
      <span class="spotify__equalizer" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </span>
    </div>
  </div>

  <!-- Info rows -->
  {cards.map(card => (
    <div class="glass-card">
      <div class="glass-card__content row">
        <span class="row__label">{card.label}</span>
        <span class="row__text">{card.text}</span>
      </div>
    </div>
  ))}
</div>

<script>
  const IDLE = 'Not listening to anything.';
  const el = document.querySelector<HTMLElement>('[data-now-field="listening"]');
  const card = el?.closest<HTMLElement>('.glass-card--spotify');

  async function refreshListening() {
    if (!el) return;
    try {
      const res = await fetch('/api/now-playing', { cache: 'no-store' });
      if (!res.ok) return;
      const { listening } = await res.json();
      const next = listening || IDLE;
      if (next !== el.textContent) el.textContent = next;
      card?.classList.toggle('is-playing', !!listening);
    } catch {
      // keep whatever is on screen
    }
  }

  if (el) {
    if (el.textContent && el.textContent.trim() !== IDLE) {
      card?.classList.add('is-playing');
    }
    refreshListening();
    setInterval(refreshListening, 20000);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') refreshListening();
    });
  }
</script>

<style>
  .now-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 560px;
    width: 100%;
  }

  /* ── Liquid glass surface (frosted + luminous rim + specular sweep) ── */

  .glass-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    isolation: isolate;
    background: rgba(12, 10, 8, 0.45);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    /* Luminous rim: bright top inner edge, hairline border, soft inner base
       shadow for thickness, and a drop shadow to lift it off the sky. */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 -10px 24px rgba(0, 0, 0, 0.22),
      0 8px 28px rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.4s ease, background 0.4s ease, transform 0.3s ease;
  }

  /* Specular sweep — the diagonal sheen that reads as a curved glass surface */
  .glass-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      150deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.05) 18%,
      transparent 38%,
      transparent 100%
    );
  }

  /* Bright edge highlight that catches along the top rim */
  .glass-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(
      120% 80% at 50% -20%,
      rgba(255, 255, 255, 0.18) 0%,
      transparent 55%
    );
  }

  .glass-card:hover {
    background: rgba(12, 10, 8, 0.38);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      inset 0 -10px 24px rgba(0, 0, 0, 0.22),
      0 10px 34px rgba(0, 0, 0, 0.36);
    transform: translateY(-1px);
  }

  .glass-card__content {
    position: relative;
    z-index: 2;
  }

  /* ── Spotify row ── */

  .glass-card__content.spotify {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
  }

  .spotify__icon {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    color: var(--muted);
    transition: color 0.4s ease;
  }

  .glass-card--spotify.is-playing .spotify__icon {
    color: #1DB954;
  }

  .spotify__info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
    flex: 1;
  }

  .spotify__label {
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .spotify__track {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .glass-card--spotify.is-playing .spotify__track {
    color: var(--paper);
  }

  .spotify__equalizer {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .glass-card--spotify.is-playing .spotify__equalizer {
    opacity: 1;
  }

  .spotify__equalizer span {
    width: 3px;
    height: 100%;
    background: #1DB954;
    border-radius: 2px;
    transform-origin: bottom;
    animation: eq 0.9s ease-in-out infinite;
  }

  .spotify__equalizer span:nth-child(2) { animation-delay: 0.2s; }
  .spotify__equalizer span:nth-child(3) { animation-delay: 0.4s; }
  .spotify__equalizer span:nth-child(4) { animation-delay: 0.1s; }

  @keyframes eq {
    0%, 100% { transform: scaleY(0.3); }
    50% { transform: scaleY(1); }
  }

  /* ── Info rows ── */

  .glass-card__content.row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
  }

  .row__label {
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    width: 64px;
  }

  .row__text {
    font-size: var(--text-sm);
    color: var(--paper);
    line-height: 1.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .spotify__equalizer span {
      animation: none;
      transform: scaleY(0.5);
    }
    .glass-card:hover {
      transform: none;
    }
  }

  @media (max-width: 520px) {
    .glass-card__content.row {
      flex-direction: column;
      gap: 2px;
    }
    .row__label {
      width: auto;
    }
  }
</style>
