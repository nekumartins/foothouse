---
// The sky gradient renders as plain CSS immediately, no JS needed for first paint.
// JS later updates the custom properties based on the visitor's local hour.
// The colors interpolate via @property transitions declared in global.css.
---

<div class="sky" id="sky"></div>
<div class="celestial" id="celestial" aria-hidden="true">
  <div class="celestial__body celestial__sun"></div>
  <div class="celestial__body celestial__moon"></div>
</div>

<style>
  .sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bottom) 100%
    );
  }

  /* Sun/moon that arcs across the sky; position + fade driven by sky.ts. */
  .celestial {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .celestial__body {
    position: absolute;
    left: var(--celestial-x, 50%);
    top: var(--celestial-y, 20%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: left 2s ease, top 2s ease, opacity 2s ease;
  }

  .celestial__sun {
    opacity: var(--sun-opacity, 0);
    background: radial-gradient(circle at 50% 50%,
      rgba(255, 244, 222, 0.95) 0%,
      rgba(245, 206, 130, 0.85) 38%,
      rgba(224, 164, 88, 0.35) 60%,
      rgba(224, 164, 88, 0) 72%);
    box-shadow: 0 0 60px 20px rgba(245, 206, 130, 0.25),
                0 0 120px 50px rgba(224, 164, 88, 0.12);
  }

  .celestial__moon {
    opacity: var(--moon-opacity, 0);
    background: radial-gradient(circle at 42% 42%,
      rgba(236, 233, 226, 0.92) 0%,
      rgba(206, 208, 220, 0.7) 45%,
      rgba(180, 185, 205, 0.18) 64%,
      rgba(180, 185, 205, 0) 74%);
    box-shadow: 0 0 40px 12px rgba(206, 208, 220, 0.16),
                0 0 90px 36px rgba(180, 185, 205, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .celestial__body {
      transition: none;
    }
  }
</style>
