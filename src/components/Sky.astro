---
// The sky gradient renders as plain CSS immediately, no JS needed for first paint.
// JS later updates the custom properties based on the visitor's local hour.
// The colors interpolate via @property transitions declared in global.css.
---

<div class="sky" id="sky"></div>
<div class="celestial" id="celestial" aria-hidden="true">
  <div class="celestial__body celestial__sun"></div>
  <div class="celestial__body celestial__moon">
    <!-- A real moon: soft disc, a handful of quiet craters, a whisper of grain. -->
    <svg viewBox="0 0 46 46" width="46" height="46" aria-hidden="true">
      <defs>
        <radialGradient id="fh-moon-disc" cx="42%" cy="42%" r="62%">
          <stop offset="0%" stop-color="rgba(236, 233, 226, 0.72)" />
          <stop offset="55%" stop-color="rgba(210, 212, 221, 0.5)" />
          <stop offset="82%" stop-color="rgba(182, 186, 204, 0.2)" />
          <stop offset="100%" stop-color="rgba(182, 186, 204, 0)" />
        </radialGradient>
        <radialGradient id="fh-moon-fade-grad" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#fff" />
          <stop offset="68%" stop-color="#fff" />
          <stop offset="100%" stop-color="#fff" stop-opacity="0" />
        </radialGradient>
        <mask id="fh-moon-fade">
          <circle cx="23" cy="23" r="21" fill="url(#fh-moon-fade-grad)" />
        </mask>
        <filter id="fh-moon-grain" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" seed="7" result="noise" />
          <feColorMatrix
            in="noise"
            type="matrix"
            values="0 0 0 0 0.88  0 0 0 0 0.88  0 0 0 0 0.92  0 0 0 0.6 0"
          />
          <feComposite operator="in" in2="SourceGraphic" />
        </filter>
      </defs>

      <circle cx="23" cy="23" r="21" fill="url(#fh-moon-disc)" />

      <g mask="url(#fh-moon-fade)">
        <g fill="rgba(150, 155, 175, 0.22)" stroke="rgba(245, 243, 238, 0.09)" stroke-width="0.6">
          <circle cx="16" cy="14" r="3.4" />
          <circle cx="29" cy="18" r="2.2" />
          <circle cx="20" cy="27" r="4.6" />
          <circle cx="30.5" cy="29.5" r="2.6" />
          <circle cx="13" cy="22.5" r="1.8" />
          <circle cx="25" cy="10.5" r="1.5" />
        </g>
        <circle class="celestial__moon-grain" cx="23" cy="23" r="21" fill="rgba(216, 218, 228, 1)" filter="url(#fh-moon-grain)" opacity="0.09" />
      </g>
    </svg>
  </div>
</div>

<style>
  .sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bottom) 100%
    );
  }

  /* Sun/moon that arcs across the sky; position + fade driven by sky.ts. */
  .celestial {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .celestial__body {
    position: absolute;
    left: var(--celestial-x, 50%);
    top: var(--celestial-y, 20%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: left var(--sky-ease, 6s) var(--sky-ease-fn, linear),
                top var(--sky-ease, 6s) var(--sky-ease-fn, linear),
                opacity var(--sky-ease, 6s) var(--sky-ease-fn, linear);
  }

  .celestial__sun {
    opacity: var(--sun-opacity, 0);
    background: radial-gradient(circle at 50% 50%,
      rgba(252, 238, 210, 0.72) 0%,
      rgba(245, 206, 130, 0.55) 42%,
      rgba(224, 164, 88, 0.2) 64%,
      rgba(224, 164, 88, 0) 74%);
    box-shadow: 0 0 26px 6px rgba(245, 206, 130, 0.18),
                0 0 50px 16px rgba(224, 164, 88, 0.08);
  }

  .celestial__moon {
    opacity: var(--moon-opacity, 0);
    box-shadow: 0 0 22px 5px rgba(206, 208, 220, 0.12),
                0 0 44px 14px rgba(180, 185, 205, 0.06);
  }

  .celestial__moon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .celestial__body {
      transition: none;
    }
  }
</style>
