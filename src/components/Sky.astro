---
// The sky gradient renders as plain CSS immediately, no JS needed for first paint.
// JS later updates the custom properties based on the visitor's local hour.
// The colors interpolate via @property transitions declared in global.css.
---

<div class="sky" id="sky"></div>
<div class="celestial" id="celestial" aria-hidden="true">
  <div class="celestial__body celestial__sun"></div>
  <div class="celestial__body celestial__moon">
    <svg viewBox="0 0 46 46" width="46" height="46" aria-hidden="true">
      <defs>
        <radialGradient id="fh-moon-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(237, 234, 224, 0.16)" />
          <stop offset="50%" stop-color="rgba(210, 212, 225, 0.07)" />
          <stop offset="100%" stop-color="rgba(210, 212, 225, 0)" />
        </radialGradient>
        <mask id="fh-crescent">
          <circle cx="23" cy="23" r="16" fill="#fff" />
          <circle cx="29.5" cy="18.5" r="14.5" fill="#000" />
        </mask>
      </defs>
      <circle cx="23" cy="23" r="30" fill="url(#fh-moon-glow)" />
      <circle cx="23" cy="23" r="16" fill="#EDEAE0" opacity="0.9" mask="url(#fh-crescent)" />
    </svg>
  </div>
</div>

<style>
  .sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 50%,
      var(--sky-bottom) 100%
    );
  }

  /* Sun/moon that arcs across the sky; position + fade driven by sky.ts. */
  .celestial {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .celestial__body {
    position: absolute;
    left: var(--celestial-x, 50%);
    top: var(--celestial-y, 20%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: left var(--sky-ease, 6s) var(--sky-ease-fn, linear),
                top var(--sky-ease, 6s) var(--sky-ease-fn, linear),
                opacity var(--sky-ease, 6s) var(--sky-ease-fn, linear);
  }

  .celestial__sun {
    opacity: var(--sun-opacity, 0);
    background: radial-gradient(circle at 50% 50%,
      rgba(252, 238, 210, 0.72) 0%,
      rgba(245, 206, 130, 0.55) 42%,
      rgba(224, 164, 88, 0.2) 64%,
      rgba(224, 164, 88, 0) 74%);
    box-shadow: 0 0 26px 6px rgba(245, 206, 130, 0.18),
                0 0 50px 16px rgba(224, 164, 88, 0.08);
  }

  .celestial__moon {
    opacity: var(--moon-opacity, 0);
  }

  .celestial__moon svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  @media (prefers-reduced-motion: reduce) {
    .celestial__body {
      transition: none;
    }
  }
</style>
