---
// Soft drifting clouds. They give the daytime sky real texture — which is
// what the glass refraction needs behind it to actually show a bend — and
// fade out toward night. Opacity/tint is driven by the sky-update event.
---

<canvas id="clouds-canvas" class="clouds" aria-hidden="true"></canvas>

<script>
  import { lerpColor, getCelestial } from '../scripts/sky';

  const canvas = document.getElementById('clouds-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  if (ctx) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Behind the inner pages' blur, a lower frame rate is indistinguishable.
    const receded = document.body.dataset.skyMode === 'receded';

    interface Cloud {
      x: number;
      y: number;
      scale: number;
      speed: number;
      puffs: Array<{ dx: number; dy: number; r: number }>;
    }

    let clouds: Cloud[] = [];
    let width = 0;
    let height = 0;
    let targetOpacity = 0;
    let currentOpacity = 0;
    let tint = '236, 232, 224'; // lit body of the cloud
    let underTint = '200, 190, 180'; // shaded underside, warms at golden hour
    let lightX = 0.5; // sun/moon position across the sky, 0..1

    function hexToRgbString(hex: string): string {
      const v = parseInt(hex.slice(1), 16);
      return `${(v >> 16) & 0xff}, ${(v >> 8) & 0xff}, ${v & 0xff}`;
    }

    // Clouds take their color from the live sky palette: the lit body leans
    // toward warm white, the underside keeps the horizon color, so golden
    // hour warms the cloud bases for free.
    function tintFromPalette(palette: { mid: string; bottom: string }) {
      tint = hexToRgbString(lerpColor(palette.mid, '#F4F0E8', 0.65));
      underTint = hexToRgbString(lerpColor(palette.bottom, '#F4F0E8', 0.25));
    }

    function makeCloud(startX?: number): Cloud {
      const scale = 0.6 + Math.random() * 1.1;
      const puffCount = 4 + Math.floor(Math.random() * 4);
      const puffs: Cloud['puffs'] = [];
      let spread = 0;
      for (let i = 0; i < puffCount; i++) {
        const dx = spread;
        // Lumpy tops, flat-ish bottoms: puffs only rise above the baseline.
        const dy = -Math.random() * 24;
        const r = (30 + Math.random() * 40);
        puffs.push({ dx, dy, r });
        spread += r * 0.7;
      }
      // one wide, low puff as the cloud's base
      puffs.push({ dx: spread / 2, dy: 10, r: spread * 0.42 });
      // centre the cluster
      const mid = spread / 2;
      for (const p of puffs) p.dx -= mid;

      return {
        x: startX ?? Math.random() * width,
        y: Math.random() * height * 0.55,
        scale,
        speed: (0.04 + Math.random() * 0.06) * scale,
        puffs,
      };
    }

    function rebuild() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width * devicePixelRatio;
      canvas.height = height * devicePixelRatio;
      canvas.style.width = width + 'px';
      canvas.style.height = height + 'px';
      ctx!.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);

      const count = Math.max(3, Math.round(width / 460));
      clouds = [];
      for (let i = 0; i < count; i++) clouds.push(makeCloud());
    }

    let resizeTimer: ReturnType<typeof setTimeout> | undefined;
    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        rebuild();
        start();
      }, 150);
    }

    function drawCloud(c: Cloud) {
      // Light leans in from wherever the sun (or moon) is.
      const lightPx = lightX * width;
      for (const p of c.puffs) {
        const r = p.r * c.scale;
        const cx = c.x + p.dx * c.scale;
        const cy = c.y + p.dy * c.scale;
        const toward = Math.max(-1, Math.min(1, (lightPx - cx) / (width * 0.5)));
        const hx = cx + toward * r * 0.25;
        const hy = cy - r * 0.18;

        const grad = ctx!.createRadialGradient(hx, hy, 0, cx, cy, r);
        grad.addColorStop(0, `rgba(${tint}, ${0.3 * currentOpacity})`);
        grad.addColorStop(0.6, `rgba(${tint}, ${0.12 * currentOpacity})`);
        grad.addColorStop(1, `rgba(${tint}, 0)`);
        ctx!.fillStyle = grad;
        ctx!.beginPath();
        ctx!.arc(cx, cy, r, 0, Math.PI * 2);
        ctx!.fill();

        // a soft shaded underside, in the horizon's color
        const uy = cy + r * 0.45;
        const under = ctx!.createRadialGradient(cx, uy, 0, cx, uy, r * 0.7);
        under.addColorStop(0, `rgba(${underTint}, ${0.1 * currentOpacity})`);
        under.addColorStop(1, `rgba(${underTint}, 0)`);
        ctx!.fillStyle = under;
        ctx!.beginPath();
        ctx!.arc(cx, uy, r * 0.7, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    // The loop only runs while there is something to animate: it stops when
    // the tab is hidden, when the clouds have fully faded, and (under
    // reduced motion) once the fade has settled on a static frame.
    let running = false;
    let frameCount = 0;

    function settled() {
      return Math.abs(targetOpacity - currentOpacity) < 0.005;
    }

    function shouldStop() {
      if (document.hidden) return true;
      if (currentOpacity < 0.01 && targetOpacity < 0.01) return true;
      if (prefersReducedMotion && settled()) return true;
      return false;
    }

    function frame() {
      if (!ctx || !running) return;
      if (shouldStop()) {
        running = false;
        return;
      }

      frameCount++;
      if (receded && frameCount % 3 !== 0) {
        requestAnimationFrame(frame);
        return;
      }

      currentOpacity += (targetOpacity - currentOpacity) * 0.02;
      ctx.clearRect(0, 0, width, height);

      if (currentOpacity > 0.01) {
        for (const c of clouds) {
          if (!prefersReducedMotion) {
            c.x += c.speed;
            const widest = Math.max(...c.puffs.map((p) => Math.abs(p.dx))) * c.scale + 100;
            if (c.x - widest > width) {
              Object.assign(c, makeCloud(-widest));
            }
          }
          drawCloud(c);
        }
      }
      requestAnimationFrame(frame);
    }

    function start() {
      if (running) return;
      running = true;
      requestAnimationFrame(frame);
    }

    // Daytime presence curve; the night floor keeps moonlit clouds present.
    function opacityForHour(hour: number): number {
      if (hour >= 9 && hour < 16) return 0.5;
      if (hour >= 7 && hour < 9) return ((hour - 7) / 2) * 0.5;
      if (hour >= 16 && hour < 19) return (1 - (hour - 16) / 3) * 0.5;
      if (hour >= 6 && hour < 7) return 0.18;
      if (hour >= 19 && hour < 20) return 0.12;
      return 0.1; // moonlit night clouds
    }

    window.addEventListener('sky-update', ((e: CustomEvent) => {
      const { hour, palette } = e.detail;
      targetOpacity = opacityForHour(hour);
      if (palette) tintFromPalette(palette);
      const celestial = getCelestial(hour);
      lightX = celestial.x / 100;
      if (!settled() || targetOpacity >= 0.01) start();
    }) as EventListener);

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) start();
    });

    // Seed from the current hour so clouds fade in immediately, before the
    // first sky-update event arrives.
    const h0 = new Date().getHours();
    targetOpacity = opacityForHour(h0);
    if (h0 >= 7 && h0 < 17) tint = '244, 240, 232';
    else if ((h0 >= 5 && h0 < 7) || (h0 >= 17 && h0 < 19)) tint = '240, 210, 170';
    else tint = '180, 185, 205';
    lightX = getCelestial(h0).x / 100;

    rebuild();
    window.addEventListener('resize', onResize);
    start();
  }
</script>

<style>
  .clouds {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
  }
</style>
