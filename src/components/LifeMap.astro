---
interface PlaceMedia {
  url: string;
  caption?: string;
}

interface Place {
  id: string;
  name: string;
  lat: number;
  lng: number;
  arrived_on?: string;
  kind: string;
  pin_type: string;
  note?: string;
  sort: number;
  place_media: PlaceMedia[];
}

interface Props {
  places: Place[];
}

const { places } = Astro.props;

// Deterministic starfield rendered server-side: same stars every build,
// zero runtime JS, zero network bytes.
function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(97);
const stars = Array.from({ length: 130 }, () => ({
  cx: Math.round(rand() * 1000),
  cy: Math.round(rand() * 1000),
  r: +(0.6 + rand() * 1.0).toFixed(2),
  o: +(0.25 + rand() * 0.55).toFixed(2),
}));
---

<div class="life-map" id="life-map-container">
  <svg
    class="life-map__stars"
    viewBox="0 0 1000 1000"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    {stars.map((s) => <circle cx={s.cx} cy={s.cy} r={s.r} fill="#ECE3D6" opacity={s.o} />)}
  </svg>
  <div class="life-map__canvas" id="life-map"></div>
  {places.length === 0 && (
    <p class="life-map__empty">No places yet. Pins will appear here as the map fills in.</p>
  )}
  <div class="life-map__lightbox" id="map-lightbox" role="dialog" aria-hidden="true">
    <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
    <div class="lightbox__content" id="lightbox-content"></div>
  </div>
</div>

<script define:vars={{ places }}>
  window.__mapPlaces = places;
</script>

<script>
  async function initMap() {
    const maplibregl = await import('maplibre-gl');
    await import('maplibre-gl/dist/maplibre-gl.css');

    const places = (window as any).__mapPlaces ?? [];

    const container = document.getElementById('life-map');
    if (!container) return;

    const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    // Retina tiles only where the screen can show them. Label-free variant:
    // labels break the planet-from-space look.
    const tileUrl = (window.devicePixelRatio ?? 1) > 1.5
      ? 'https://basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}@2x.png'
      : 'https://basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}.png';

    // Size the sphere to ~65% of the smaller canvas dimension so it floats in
    // space like Snapchat's Earth instead of overflowing the screen. Globe
    // screen diameter ≈ 512 * 2^zoom / π.
    const rect = container.getBoundingClientRect();
    const fitZoom = Math.min(
      2,
      Math.max(0, Math.log2((0.65 * Math.min(rect.width, rect.height) * Math.PI) / 512))
    );

    const map = new maplibregl.Map({
      container: 'life-map',
      style: {
        version: 8,
        sources: {
          'carto': {
            type: 'raster',
            tiles: [tileUrl],
            tileSize: 256,
            attribution: '&copy; <a href="https://carto.com/">CARTO</a>'
          }
        },
        layers: [
          {
            id: 'carto-tiles',
            type: 'raster',
            source: 'carto',
            paint: {
              'raster-saturation': -0.2,
              'raster-brightness-max': 0.35,
              'raster-contrast': 0.15
            }
          }
        ],
        sky: {
          // MapLibre's built-in globe atmosphere is the blue rim glow; fade it
          // out as the visitor zooms in toward street level.
          'atmosphere-blend': ['interpolate', ['linear'], ['zoom'], 0, 1, 5, 1, 7, 0]
        },
        // Globe projection lives in the style in MapLibre v5; as a Map
        // constructor option it is silently ignored and the map renders flat.
        projection: { type: 'globe' }
      },
      // A small globe floating in space, Snapchat-style: the whole sphere sits
      // centered on the starfield with Nigeria facing forward. It is static
      // until dragged; a one-finger drag spins it.
      center: [8.6753, 9.0820] as [number, number],
      zoom: fitZoom,
      minZoom: fitZoom,
      maxZoom: 15,
      attributionControl: false,
    });

    map.addControl(new maplibregl.AttributionControl({ compact: true }), 'bottom-right');

    // Scroll-wheel/trackpad zoom fights with page scroll on touch devices;
    // pinch-zoom (touchZoomRotate, on by default) stays enabled either way.
    if (isTouch) map.scrollZoom.disable();

    const kindColors: Record<string, string> = {
      home: '#E0A458',
      travel: '#C57B4E',
      event: '#9A8C7B',
    };

    const lightbox = document.getElementById('map-lightbox')!;
    const lightboxContent = document.getElementById('lightbox-content')!;
    const lightboxClose = document.getElementById('lightbox-close')!;

    // Navigation handler for the open carousel; null when the lightbox is closed.
    let activeNav: ((dir: number) => void) | null = null;

    function closeLightbox() {
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxContent.innerHTML = '';
      activeNav = null;
    }

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox.getAttribute('aria-hidden') === 'true') return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowLeft') activeNav?.(-1);
      else if (e.key === 'ArrowRight') activeNav?.(1);
    });

    const escapeHtml = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function openPlace(place: any) {
      const media = place.place_media ?? [];
      const name = escapeHtml(place.name ?? '');

      let html = `<h3 class="lightbox__title">${name}</h3>`;
      if (place.note) html += `<p class="lightbox__note">${escapeHtml(place.note)}</p>`;

      if (media.length > 0) {
        const slides = media.map((m: any) => `
          <div class="lightbox__slide">
            <img src="${m.url}" alt="${escapeHtml(m.caption || place.name || '')}" loading="lazy" class="lightbox__img" />
            ${m.caption ? `<figcaption class="lightbox__caption">${escapeHtml(m.caption)}</figcaption>` : ''}
          </div>`).join('');

        const multi = media.length > 1;
        const dots = multi
          ? `<div class="lightbox__dots">${media.map((_: any, i: number) =>
              `<span class="lightbox__dot${i === 0 ? ' is-active' : ''}"></span>`).join('')}</div>`
          : '';
        const arrows = multi
          ? `<button class="lightbox__arrow lightbox__arrow--prev" aria-label="Previous">&#8249;</button>
             <button class="lightbox__arrow lightbox__arrow--next" aria-label="Next">&#8250;</button>`
          : '';
        const counter = multi ? `<div class="lightbox__counter">1 / ${media.length}</div>` : '';

        html += `<div class="lightbox__carousel"${multi ? '' : ' data-single'}>
          <div class="lightbox__viewport">
            <div class="lightbox__track">${slides}</div>
          </div>
          ${arrows}
          ${counter}
          ${dots}
        </div>`;
      }

      lightboxContent.innerHTML = html;
      lightbox.setAttribute('aria-hidden', 'false');

      const track = lightboxContent.querySelector<HTMLElement>('.lightbox__track');
      if (!track || media.length <= 1) {
        activeNav = null;
        return;
      }

      const counterEl = lightboxContent.querySelector<HTMLElement>('.lightbox__counter');
      const dotEls = Array.from(lightboxContent.querySelectorAll<HTMLElement>('.lightbox__dot'));
      let index = 0;

      const go = (dir: number) => {
        index = (index + dir + media.length) % media.length;
        track.style.transform = `translateX(-${index * 100}%)`;
        if (counterEl) counterEl.textContent = `${index + 1} / ${media.length}`;
        dotEls.forEach((d, i) => d.classList.toggle('is-active', i === index));
      };
      activeNav = go;

      lightboxContent.querySelector('.lightbox__arrow--prev')?.addEventListener('click', () => go(-1));
      lightboxContent.querySelector('.lightbox__arrow--next')?.addEventListener('click', () => go(1));
      dotEls.forEach((d, i) => d.addEventListener('click', () => go(i - index)));

      // Touch swipe
      let startX = 0;
      const viewport = lightboxContent.querySelector<HTMLElement>('.lightbox__viewport');
      viewport?.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
      viewport?.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
      }, { passive: true });
    }

    const travelPins = places
      .filter((p: any) => p.kind === 'travel' && p.arrived_on)
      .sort((a: any, b: any) => new Date(a.arrived_on).getTime() - new Date(b.arrived_on).getTime());

    if (travelPins.length >= 2) {
      map.on('load', () => {
        const coords = travelPins.map((p: any) => [p.lng, p.lat]);
        map.addSource('travel-route', {
          type: 'geojson',
          data: {
            type: 'Feature',
            properties: {},
            geometry: { type: 'LineString', coordinates: coords },
          },
        });
        map.addLayer({
          id: 'travel-route-line',
          type: 'line',
          source: 'travel-route',
          paint: {
            'line-color': '#C57B4E',
            'line-opacity': 0.3,
            'line-width': 1.5,
            'line-dasharray': [4, 4],
          },
        });
      });
    }

    for (const place of places) {
      const color = kindColors[place.kind] || '#9A8C7B';
      const media = place.place_media ?? [];
      const hasMedia = media.length > 0;

      // Marker root: MapLibre owns its transform — never touch it (that caused the
      // "runaway" jump). All visuals live in the inner bubble, scaled via CSS hover.
      const el = document.createElement('div');
      el.className = 'map-pin';

      const bubble = document.createElement('div');
      bubble.title = place.name ?? '';

      if (hasMedia) {
        bubble.className = 'map-pin__bubble';
        bubble.style.setProperty('--pin-color', color);
        // Request a small thumbnail variant for the bubble to keep it light.
        const thumb = String(media[0].url).replace('w=1200', 'w=160');
        bubble.style.backgroundImage = `url("${thumb}")`;
        if (media.length > 1) {
          const badge = document.createElement('span');
          badge.className = 'map-pin__count';
          badge.textContent = String(media.length);
          bubble.appendChild(badge);
        }
      } else {
        bubble.className = 'map-pin__dot';
        bubble.style.setProperty('--pin-color', color);
      }

      el.appendChild(bubble);

      // Lift a hovered pin above its neighbors without touching the root transform.
      el.addEventListener('mouseenter', () => { el.style.zIndex = '10'; });
      el.addEventListener('mouseleave', () => { el.style.zIndex = ''; });
      el.addEventListener('click', () => openPlace(place));

      new maplibregl.Marker({ element: el, anchor: hasMedia ? 'bottom' : 'center' })
        .setLngLat([place.lng, place.lat])
        .addTo(map);
    }

  }

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          initMap();
        }
      },
      { rootMargin: '200px' }
    );
    const el = document.getElementById('life-map-container');
    if (el) observer.observe(el);
  } else {
    initMap();
  }
</script>

<style>
  .life-map {
    position: relative;
    width: 100%;
    height: calc(100vh - 80px);
    min-height: 400px;
    /* Outer space, deliberately blacker and cooler than the site's warm --bg.
       Opaque so the look holds at forced noon and forced midnight. */
    background: #050608;
    overflow: hidden;
  }

  .life-map__stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .life-map__canvas {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }

  .life-map__empty {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-xl);
    color: var(--muted);
    font-size: var(--text-sm);
    pointer-events: none;
  }

  /* ── Snap-style pins ── */

  .life-map__canvas :global(.map-pin) {
    cursor: pointer;
    line-height: 0;
  }

  .life-map__canvas :global(.map-pin__bubble) {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    background-color: rgba(30, 24, 19, 0.6);
    border: 2px solid var(--pin-color, #9A8C7B);
    box-shadow: 0 0 0 2px rgba(21, 17, 13, 0.5), 0 2px 10px rgba(0, 0, 0, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  /* Downward tail that points at the coordinate (marker is bottom-anchored). */
  .life-map__canvas :global(.map-pin__bubble::after) {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -7px;
    width: 10px;
    height: 10px;
    background: var(--pin-color, #9A8C7B);
    transform: translateX(-50%) rotate(45deg);
    border-radius: 0 0 2px 0;
  }

  .life-map__canvas :global(.map-pin__bubble:hover) {
    transform: scale(1.1);
    box-shadow: 0 0 0 2px rgba(21, 17, 13, 0.5), 0 0 16px var(--pin-color, #9A8C7B), 0 4px 14px rgba(0, 0, 0, 0.5);
  }

  .life-map__canvas :global(.map-pin__count) {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 9px;
    background: rgba(21, 17, 13, 0.92);
    border: 1px solid var(--pin-color, #9A8C7B);
    color: #ECE3D6;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    line-height: 18px;
    text-align: center;
  }

  .life-map__canvas :global(.map-pin__dot) {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--pin-color, #9A8C7B);
    border: 2px solid rgba(236, 227, 214, 0.2);
    box-shadow: 0 0 8px color-mix(in srgb, var(--pin-color, #9A8C7B) 40%, transparent),
                0 0 16px color-mix(in srgb, var(--pin-color, #9A8C7B) 20%, transparent);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .life-map__canvas :global(.map-pin__dot:hover) {
    transform: scale(1.3);
    box-shadow: 0 0 12px color-mix(in srgb, var(--pin-color, #9A8C7B) 55%, transparent),
                0 0 24px color-mix(in srgb, var(--pin-color, #9A8C7B) 35%, transparent);
  }

  .life-map__canvas :global(.maplibregl-popup-content) {
    background: rgba(30, 24, 19, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #ECE3D6;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid rgba(236, 227, 214, 0.1);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .life-map__canvas :global(.maplibregl-popup-tip) {
    border-top-color: rgba(30, 24, 19, 0.9);
  }

  .life-map__lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(21, 17, 13, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .life-map__lightbox[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox__close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    background: none;
    border: none;
    color: var(--paper);
    font-size: var(--text-3xl);
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.3s ease;
    line-height: 1;
    z-index: 201;
  }

  .lightbox__close:hover {
    opacity: 1;
  }

  .lightbox__content {
    max-width: 720px;
    width: 100%;
    max-height: 85vh;
    padding: var(--space-xl);
    text-align: center;
  }

  .lightbox__content :global(.lightbox__title) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-sm);
  }

  .lightbox__content :global(.lightbox__note) {
    font-size: var(--text-sm);
    color: var(--muted);
    margin-bottom: var(--space-xl);
  }

  /* ── Carousel ── */

  .lightbox__content :global(.lightbox__carousel) {
    position: relative;
    width: 100%;
  }

  .lightbox__content :global(.lightbox__viewport) {
    overflow: hidden;
    border-radius: 8px;
  }

  .lightbox__content :global(.lightbox__track) {
    display: flex;
    transition: transform 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox__content :global(.lightbox__track) {
      transition: none;
    }
  }

  .lightbox__content :global(.lightbox__slide) {
    flex: 0 0 100%;
    min-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .lightbox__content :global(.lightbox__img) {
    max-width: 100%;
    max-height: 64vh;
    border-radius: 8px;
    object-fit: contain;
  }

  .lightbox__content :global(.lightbox__caption) {
    font-size: var(--text-xs);
    color: var(--faint);
    margin-top: var(--space-sm);
  }

  .lightbox__content :global(.lightbox__arrow) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(21, 17, 13, 0.6);
    border: 1px solid rgba(236, 227, 214, 0.15);
    border-radius: 50%;
    color: var(--paper);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  .lightbox__content :global(.lightbox__arrow:hover) {
    opacity: 1;
    background: rgba(21, 17, 13, 0.85);
  }

  .lightbox__content :global(.lightbox__arrow--prev) { left: -8px; }
  .lightbox__content :global(.lightbox__arrow--next) { right: -8px; }

  .lightbox__content :global(.lightbox__counter) {
    margin-top: var(--space-md);
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .lightbox__content :global(.lightbox__dots) {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: var(--space-sm);
  }

  .lightbox__content :global(.lightbox__dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(236, 227, 214, 0.25);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .lightbox__content :global(.lightbox__dot.is-active) {
    background: var(--lamp);
    transform: scale(1.3);
  }

  @media (max-width: 480px) {
    .lightbox__content :global(.lightbox__arrow--prev) { left: 4px; }
    .lightbox__content :global(.lightbox__arrow--next) { right: 4px; }
  }

  @media (max-width: 480px) {
    .lightbox__content {
      padding: var(--space-md);
    }
  }
</style>
