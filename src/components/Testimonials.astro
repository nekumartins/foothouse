---
interface Props {
  testimonials: { id: string; quote: string; name: string; business?: string }[];
}
const { testimonials } = Astro.props;
---

<section class="testimonials">
  <h2 class="section-label">What clients say</h2>
  <div class="testimonials__list">
    {testimonials.map((t) => (
      <blockquote class="testimonial">
        <p class="testimonial__quote">{t.quote}</p>
        <footer class="testimonial__attribution">
          {t.name}{t.business ? `, ${t.business}` : ''}
        </footer>
      </blockquote>
    ))}
  </div>
</section>

<style>
  .testimonials {
    max-width: 720px;
    width: 100%;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }

  .testimonials__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-lg);
  }

  .testimonial {
    padding: var(--space-xl);
    background: rgba(30, 24, 19, 0.25);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 12px;
  }

  .testimonial__quote {
    font-size: var(--text-base);
    color: var(--paper);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .testimonial__attribution {
    font-size: var(--text-sm);
    color: var(--muted);
    font-style: normal;
  }
</style>
