          <stop offset="0" style="stop-color: var(--cloud-hi)" />
          <stop offset="1" style="stop-color: var(--cloud-lo)" />
        </linearGradient>
      </defs>
      <rect x="0" y="118" width="800" height="82" fill="url(#cb-back)" />
      <circle cx="40" cy="120" r="34" fill="url(#cb-back)" />
      <circle cx="120" cy="112" r="48" fill="url(#cb-back)" />
      <circle cx="210" cy="120" r="30" fill="url(#cb-back)" />
      <circle cx="300" cy="108" r="56" fill="url(#cb-back)" />
      <circle cx="395" cy="118" r="38" fill="url(#cb-back)" />
      <circle cx="470" cy="104" r="60" fill="url(#cb-back)" />
      <circle cx="570" cy="116" r="42" fill="url(#cb-back)" />
      <circle cx="650" cy="108" r="52" fill="url(#cb-back)" />
      <circle cx="740" cy="118" r="36" fill="url(#cb-back)" />
      <circle cx="790" cy="112" r="44" fill="url(#cb-back)" />
      <circle cx="-10" cy="112" r="44" fill="url(#cb-back)" />
    </svg>
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" width="100%" height="100%">
      <rect x="0" y="118" width="800" height="82" fill="url(#cb-back)" />
      <circle cx="40" cy="120" r="34" fill="url(#cb-back)" />
      <circle cx="120" cy="112" r="48" fill="url(#cb-back)" />
      <circle cx="210" cy="120" r="30" fill="url(#cb-back)" />
      <circle cx="300" cy="108" r="56" fill="url(#cb-back)" />
      <circle cx="395" cy="118" r="38" fill="url(#cb-back)" />
      <circle cx="470" cy="104" r="60" fill="url(#cb-back)" />
      <circle cx="570" cy="116" r="42" fill="url(#cb-back)" />
      <circle cx="650" cy="108" r="52" fill="url(#cb-back)" />
      <circle cx="740" cy="118" r="36" fill="url(#cb-back)" />
      <circle cx="790" cy="112" r="44" fill="url(#cb-back)" />
      <circle cx="-10" cy="112" r="44" fill="url(#cb-back)" />
    </svg>
    <!-- second copy intentionally omits <defs>: SVG ids are document-global -->
  </div>

  <div class="cloudbed__layer cloudbed__layer--mid">
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" width="100%" height="100%">
      <defs>
        <linearGradient id="cb-mid" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" style="stop-color: var(--cloud-hi)" />
          <stop offset="1" style="stop-color: var(--cloud-lo)" />
        </linearGradient>
      </defs>
      <rect x="0" y="116" width="800" height="84" fill="url(#cb-mid)" />
      <circle cx="30" cy="124" r="40" fill="url(#cb-mid)" />
      <circle cx="830" cy="124" r="40" fill="url(#cb-mid)" />
      <circle cx="130" cy="110" r="58" fill="url(#cb-mid)" />
      <circle cx="240" cy="120" r="36" fill="url(#cb-mid)" />
      <circle cx="330" cy="102" r="64" fill="url(#cb-mid)" />
      <circle cx="430" cy="116" r="44" fill="url(#cb-mid)" />
      <circle cx="520" cy="100" r="66" fill="url(#cb-mid)" />
      <circle cx="620" cy="114" r="46" fill="url(#cb-mid)" />
      <circle cx="710" cy="104" r="58" fill="url(#cb-mid)" />
      <circle cx="780" cy="120" r="38" fill="url(#cb-mid)" />
      <circle cx="-20" cy="120" r="38" fill="url(#cb-mid)" />
    </svg>
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" width="100%" height="100%">
      <rect x="0" y="116" width="800" height="84" fill="url(#cb-mid)" />
      <circle cx="30" cy="124" r="40" fill="url(#cb-mid)" />
      <circle cx="830" cy="124" r="40" fill="url(#cb-mid)" />
      <circle cx="130" cy="110" r="58" fill="url(#cb-mid)" />
      <circle cx="240" cy="120" r="36" fill="url(#cb-mid)" />
      <circle cx="330" cy="102" r="64" fill="url(#cb-mid)" />
      <circle cx="430" cy="116" r="44" fill="url(#cb-mid)" />
      <circle cx="520" cy="100" r="66" fill="url(#cb-mid)" />
      <circle cx="620" cy="114" r="46" fill="url(#cb-mid)" />
      <circle cx="710" cy="104" r="58" fill="url(#cb-mid)" />
      <circle cx="780" cy="120" r="38" fill="url(#cb-mid)" />
      <circle cx="-20" cy="120" r="38" fill="url(#cb-mid)" />
    </svg>
