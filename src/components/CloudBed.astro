---
// Illustrated cloud bank anchored to the bottom of the viewport, plus two
// small floaters drifting high in the sky. Colored entirely by the
// --cloud-hi/--cloud-lo custom properties, which sky.ts already crossfades
// continuously with the rest of the sky. No JS in this component.
//
// Roundness: each layer SVG is sized `height:100%; width:auto`, so its element
// aspect ratio always equals its viewBox aspect ratio. Circles stay round at
// any viewport width (the old preserveAspectRatio="none" + width:100% stretched
// them into ovals). Softness: each layer's silhouette is passed through an SVG
// feGaussianBlur so the boundary feathers instead of reading as a hard circle
// arc, and a tall connected base means the circles poke out as gentle billows
// rather than a stack of defined balls. Seamlessness: each layer holds two
// identical copies in a flex row and drifts by -50%; circles near the 0 / VBW
// edges get an auto-generated wrap partner so the bank is continuous across the
// copy seam.

const VBW = 2000;
const VBH = 160;
const WRAP = 120; // circles within this of an edge get a wrap-partner copy

type Puff = { cx: number; cy: number; r: number };

function withWraps(circles: Puff[]): Puff[] {
  const out: Puff[] = [];
  for (const c of circles) {
    out.push(c);
    if (c.cx < WRAP) out.push({ ...c, cx: c.cx + VBW });
    if (c.cx > VBW - WRAP) out.push({ ...c, cx: c.cx - VBW });
  }
  return out;
}

// blur = feGaussianBlur stdDeviation in viewBox units; larger = softer edge.
// Farther layers are softer (atmospheric depth); the front stays legible but
// is still feathered so it never reads as crisp circles.
const layers = [
  {
    id: 'cb-back',
    cls: 'cloudbed__layer--back',
    blur: 11,
    base: { y: 100, h: 60 },
    circles: withWraps([
      { cx: 60, cy: 122, r: 44 }, { cx: 170, cy: 114, r: 56 }, { cx: 300, cy: 122, r: 38 },
      { cx: 410, cy: 110, r: 60 }, { cx: 540, cy: 120, r: 44 }, { cx: 670, cy: 112, r: 54 },
      { cx: 800, cy: 122, r: 40 }, { cx: 930, cy: 112, r: 56 }, { cx: 1070, cy: 120, r: 44 },
      { cx: 1200, cy: 110, r: 58 }, { cx: 1340, cy: 122, r: 40 }, { cx: 1470, cy: 112, r: 54 },
      { cx: 1600, cy: 122, r: 42 }, { cx: 1730, cy: 112, r: 56 }, { cx: 1860, cy: 120, r: 44 },
      { cx: 1970, cy: 114, r: 50 },
    ]),
  },
  {
    id: 'cb-mid',
    cls: 'cloudbed__layer--mid',
    blur: 8,
    base: { y: 96, h: 64 },
    circles: withWraps([
      { cx: 20, cy: 124, r: 52 }, { cx: 120, cy: 110, r: 68 }, { cx: 240, cy: 120, r: 48 },
      { cx: 340, cy: 104, r: 74 }, { cx: 470, cy: 116, r: 56 }, { cx: 600, cy: 106, r: 70 },
      { cx: 720, cy: 120, r: 48 }, { cx: 840, cy: 108, r: 66 }, { cx: 980, cy: 116, r: 54 },
      { cx: 1100, cy: 104, r: 72 }, { cx: 1240, cy: 118, r: 50 }, { cx: 1360, cy: 106, r: 68 },
      { cx: 1500, cy: 118, r: 52 }, { cx: 1620, cy: 106, r: 70 }, { cx: 1760, cy: 120, r: 48 },
      { cx: 1880, cy: 110, r: 62 },
    ]),
  },
  {
    id: 'cb-front',
    cls: 'cloudbed__layer--front',
    blur: 5.5,
    base: { y: 92, h: 68 },
    circles: withWraps([
      { cx: 40, cy: 120, r: 60 }, { cx: 150, cy: 104, r: 84 }, { cx: 280, cy: 118, r: 56 },
      { cx: 380, cy: 98, r: 96 }, { cx: 520, cy: 112, r: 64 }, { cx: 640, cy: 100, r: 88 },
      { cx: 760, cy: 116, r: 56 }, { cx: 880, cy: 104, r: 78 }, { cx: 1020, cy: 110, r: 66 },
      { cx: 1140, cy: 98, r: 94 }, { cx: 1290, cy: 114, r: 58 }, { cx: 1400, cy: 102, r: 84 },
      { cx: 1540, cy: 116, r: 60 }, { cx: 1660, cy: 100, r: 90 }, { cx: 1800, cy: 114, r: 62 },
      { cx: 1930, cy: 106, r: 78 },
    ]),
  },
];
---

<div class="cloudbed" aria-hidden="true">
  {layers.map((layer) => (
    <div class:list={['cloudbed__layer', layer.cls]}>
      {[0, 1].map((copy) => (
        <svg viewBox={`0 0 ${VBW} ${VBH}`} preserveAspectRatio="xMidYMax meet">
          {copy === 0 && (
            <defs>
              <linearGradient id={layer.id} x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" style="stop-color: var(--cloud-hi)" />
                <stop offset="1" style="stop-color: var(--cloud-lo)" />
              </linearGradient>
              <filter id={`soft-${layer.id}`} x="-5%" y="-80%" width="110%" height="220%">
                <feGaussianBlur stdDeviation={layer.blur} />
              </filter>
            </defs>
          )}
          <g filter={`url(#soft-${layer.id})`}>
            <rect x="0" y={layer.base.y} width={VBW} height={layer.base.h} fill={`url(#${layer.id})`} />
            {layer.circles.map((c) => (
              <circle cx={c.cx} cy={c.cy} r={c.r} fill={`url(#${layer.id})`} />
            ))}
          </g>
        </svg>
      ))}
    </div>
  ))}

  <svg class="cloudbed__floater cloudbed__floater--one" viewBox="0 0 140 60">
    <defs>
      <linearGradient id="cb-f1" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" style="stop-color: var(--cloud-hi)" />
        <stop offset="1" style="stop-color: var(--cloud-lo)" />
      </linearGradient>
      <filter id="soft-cb-f1" x="-15%" y="-40%" width="130%" height="180%">
        <feGaussianBlur stdDeviation="2.6" />
      </filter>
    </defs>
    <g filter="url(#soft-cb-f1)">
      <rect x="8" y="36" width="118" height="12" rx="6" fill="url(#cb-f1)" />
      <circle cx="24" cy="36" r="18" fill="url(#cb-f1)" />
      <circle cx="52" cy="26" r="24" fill="url(#cb-f1)" />
      <circle cx="84" cy="32" r="20" fill="url(#cb-f1)" />
      <circle cx="110" cy="38" r="14" fill="url(#cb-f1)" />
    </g>
  </svg>

  <svg class="cloudbed__floater cloudbed__floater--two" viewBox="0 0 140 60">
    <defs>
      <linearGradient id="cb-f2" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" style="stop-color: var(--cloud-hi)" />
        <stop offset="1" style="stop-color: var(--cloud-lo)" />
      </linearGradient>
      <filter id="soft-cb-f2" x="-15%" y="-40%" width="130%" height="180%">
        <feGaussianBlur stdDeviation="2.6" />
      </filter>
    </defs>
    <g filter="url(#soft-cb-f2)">
      <rect x="8" y="36" width="118" height="12" rx="6" fill="url(#cb-f2)" />
      <circle cx="24" cy="36" r="18" fill="url(#cb-f2)" />
      <circle cx="52" cy="26" r="24" fill="url(#cb-f2)" />
      <circle cx="84" cy="32" r="20" fill="url(#cb-f2)" />
      <circle cx="110" cy="38" r="14" fill="url(#cb-f2)" />
    </g>
  </svg>
</div>

<style>
  .cloudbed {
    position: absolute;
    inset: auto 0 0 0;
    height: clamp(120px, 18vh, 220px);
    overflow: hidden;
    pointer-events: none;
  }

  /* Each layer is two identical copies in a row; it drifts by exactly one copy
     (-50%) so the loop is seamless. width:max-content lets the copies take their
     intrinsic (aspect-correct) width instead of being stretched to the box. */
  .cloudbed__layer {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 100%;
    width: max-content;
    display: flex;
    align-items: flex-end;
  }

  /* The explicit aspect-ratio (matching the viewBox) is what keeps circles
     round everywhere: iOS Safari does not derive an SVG's intrinsic ratio from
     its viewBox for CSS width:auto, so without this the layers stretch back
     into ovals on phones. Edge softness is handled by the in-SVG feGaussianBlur
     (see the filters above), not CSS blur, so it scales with the artwork. */
  .cloudbed__layer svg {
    height: 100%;
    width: auto;
    aspect-ratio: 2000 / 160;
    display: block;
    overflow: visible;
  }

  .cloudbed__layer--back {
    opacity: 0.5;
    animation: cb-drift 140s linear infinite;
  }

  .cloudbed__layer--mid {
    opacity: 0.72;
    animation: cb-drift 100s linear infinite reverse;
  }

  .cloudbed__layer--front {
    opacity: 0.92;
    animation: cb-drift 70s linear infinite;
  }

  @keyframes cb-drift {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .cloudbed__floater {
    position: fixed;
    width: 140px;
    height: auto;
    aspect-ratio: 140 / 60;
    opacity: 0.5;
    overflow: visible;
    animation: cb-float linear infinite;
  }

  .cloudbed__floater--one {
    top: 16%;
    animation-duration: 160s;
    animation-delay: -40s;
  }

  .cloudbed__floater--two {
    top: 27%;
    width: 100px;
    opacity: 0.35;
    animation-duration: 220s;
    animation-delay: -130s;
  }

  @keyframes cb-float {
    from { transform: translateX(-20vw); }
    to { transform: translateX(120vw); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloudbed__layer,
    .cloudbed__floater {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .cloudbed {
      height: clamp(96px, 14vh, 150px);
    }
  }
</style>
