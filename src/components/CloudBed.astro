  <div class="cloudbed__layer cloudbed__layer--front">
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" width="100%" height="100%">
      <defs>
        <linearGradient id="cb-front" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" style="stop-color: var(--cloud-hi)" />
          <stop offset="1" style="stop-color: var(--cloud-lo)" />
        </linearGradient>
      </defs>
      <rect x="0" y="114" width="800" height="86" fill="url(#cb-front)" />
      <circle cx="20" cy="126" r="44" fill="url(#cb-front)" />
      <circle cx="820" cy="126" r="44" fill="url(#cb-front)" />
      <circle cx="140" cy="108" r="66" fill="url(#cb-front)" />
      <circle cx="270" cy="118" r="40" fill="url(#cb-front)" />
      <circle cx="380" cy="98" r="72" fill="url(#cb-front)" />
      <circle cx="500" cy="112" r="50" fill="url(#cb-front)" />
      <circle cx="610" cy="96" r="70" fill="url(#cb-front)" />
      <circle cx="720" cy="110" r="54" fill="url(#cb-front)" />
      <circle cx="790" cy="122" r="42" fill="url(#cb-front)" />
      <circle cx="-10" cy="122" r="42" fill="url(#cb-front)" />
    </svg>
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" width="100%" height="100%">
      <rect x="0" y="114" width="800" height="86" fill="url(#cb-front)" />
      <circle cx="20" cy="126" r="44" fill="url(#cb-front)" />
      <circle cx="820" cy="126" r="44" fill="url(#cb-front)" />
      <circle cx="140" cy="108" r="66" fill="url(#cb-front)" />
      <circle cx="270" cy="118" r="40" fill="url(#cb-front)" />
      <circle cx="380" cy="98" r="72" fill="url(#cb-front)" />
      <circle cx="500" cy="112" r="50" fill="url(#cb-front)" />
      <circle cx="610" cy="96" r="70" fill="url(#cb-front)" />
      <circle cx="720" cy="110" r="54" fill="url(#cb-front)" />
