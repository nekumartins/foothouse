---
// Pages that already fetched settings pass them down; the fetch here only
// covers pages that never needed settings themselves.
import { getSiteSettings } from '../lib/queries';
import SocialLinks from './SocialLinks.astro';

interface Props {
  settings?: Record<string, any> | null;
}

const settings = Astro.props.settings !== undefined ? Astro.props.settings : await getSiteSettings();
---

<footer class="site-footer">
  <SocialLinks settings={settings} align="center" />
</footer>

<style>
  .site-footer {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    border-top: 1px solid var(--line);
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
