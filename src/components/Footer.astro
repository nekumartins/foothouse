---
// Pages that already fetched settings pass them down; the fetch here only
// covers pages that never needed settings themselves.
import { getSiteSettings } from '../lib/queries';
import SocialLinks from './SocialLinks.astro';

interface Props {
  settings?: Record<string, any> | null;
}

const settings = Astro.props.settings !== undefined ? Astro.props.settings : await getSiteSettings();
---

<footer class="site-footer">
  <SocialLinks settings={settings} align="center" />
</footer>

<style>
  /* Footer is always the last thing rendered on any page it appears on
     (standalone on interior pages, or nested as the deck's last child on
     the homepage) — reserving --chrome-clearance here, rather than on
     whatever precedes it, is what actually keeps the fixed bottom-right
     time-override control clear of content at every viewport height. */
  .site-footer {
    text-align: center;
    padding: var(--space-xl) var(--space-xl) calc(var(--space-xl) + var(--chrome-clearance));
    border-top: 1px solid var(--tint-edge);
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
