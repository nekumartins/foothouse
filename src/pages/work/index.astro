---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getProjects, getExperience, getSiteSettings } from '../../lib/queries';
import { withGithubStars } from '../../lib/github';
import { FALLBACK_PROJECTS } from '../../data/projects';

const [projects, experience, settings] = await Promise.all([
  getProjects(),
  getExperience(),
  getSiteSettings(),
]);
// Curated hard: three named projects, problem/built/outcome inline, no
// unrelated GitHub-repo padding.
const workItems = projects.length > 0 ? await withGithubStars(projects) : FALLBACK_PROJECTS;
---

<BaseLayout
  title="Work – Neku Akpotohwo"
  description="Dysseo, a real-time AI voice debate coach, and GDG on Campus Babcock. Problem, what I built, outcome."
  skyMode="receded"
>
  <div class="work">
    <header class="work__header">
      <h1>Work</h1>
      <p class="work__intro">
        Where I've worked and what I've built. Not everything, just the ones worth showing.
      </p>
    </header>

    {experience.length > 0 && (
      <section class="work__section">
        <h2 class="work__label">Experience</h2>
        <div class="experience-list">
          {experience.map((job: any) => (
            <article class="experience">
              <header class="experience__header">
                <h3 class="experience__role">
                  {job.role}
                  <span class="experience__at" aria-hidden="true"> · </span>
                  {job.url ? (
                    <a href={job.url} target="_blank" rel="noopener noreferrer" class="experience__company">
                      {job.company}
                      <svg class="experience__arrow" width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ) : (
                    <span class="experience__company">{job.company}</span>
                  )}
                </h3>
                {job.period && <span class="experience__period">{job.period}</span>}
              </header>
              {job.bullets?.length > 0 && (
                <ul class="experience__bullets">
                  {job.bullets.map((b: string) => <li>{b}</li>)}
                </ul>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {workItems.length > 0 && (
      <section class="work__section">
        <h2 class="work__label">Projects</h2>
        <div class="work__list">
          {workItems.map((project: any) => (
            <article class="work-project">
              <h3 class="work-project__name">{project.name}</h3>
              {project.tagline && <p class="work-project__tagline">{project.tagline}</p>}
              {project.problem && (
                <div class="work-project__field">
                  <h4 class="work-project__field-label">The problem</h4>
                  <p>{project.problem}</p>
                </div>
              )}
              {project.approach && (
                <div class="work-project__field">
                  <h4 class="work-project__field-label">What I built</h4>
                  <p>{project.approach}</p>
                </div>
              )}
              {project.outcome && (
                <div class="work-project__field">
                  <h4 class="work-project__field-label">Outcome</h4>
                  <p>{project.outcome}</p>
                </div>
              )}
              {(project.live_url || project.repo_url) && (
                <div class="work-project__links">
                  {project.live_url && (
                    <a href={project.live_url} target="_blank" rel="noopener noreferrer">See it live &#8599;</a>
                  )}
                  {project.repo_url && (
                    <a href={project.repo_url} target="_blank" rel="noopener noreferrer">Read the code &#8599;</a>
                  )}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {experience.length === 0 && workItems.length === 0 && (
      <p class="work__empty">Nothing here yet.</p>
    )}
  </div>

  <Footer settings={settings} />
</BaseLayout>

<style>
  .work {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .work__header {
    margin-bottom: var(--space-2xl);
  }

  .work__header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .work__intro {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .work__section {
    margin-bottom: var(--space-2xl);
  }

  .work__label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }

  /* ── Experience ── */

  .experience-list {
    display: flex;
    flex-direction: column;
  }

  .experience {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--line);
  }

  .experience:first-child {
    border-top: 1px solid var(--line);
  }

  .experience__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .experience__role {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    line-height: 1.3;
  }

  .experience__at {
    color: var(--faint);
  }

  .experience__company {
    color: var(--paper);
  }

  a.experience__company {
    color: var(--lamp);
    white-space: nowrap;
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: text-decoration-color 0.3s ease;
  }

  a.experience__company:hover {
    text-decoration-color: var(--lamp);
  }

  .experience__arrow {
    color: var(--faint);
    margin-left: 3px;
    vertical-align: baseline;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  a.experience__company:hover .experience__arrow {
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .experience__period {
    font-size: var(--text-xs);
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .experience__bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .experience__bullets li {
    position: relative;
    padding-left: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
  }

  .experience__bullets li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 0.62em;
    width: 6px;
    height: 2px;
    border-radius: 1px;
    background: color-mix(in srgb, var(--lamp) 60%, transparent);
  }

  /* ── Projects ── */

  .work__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .work-project {
    padding: var(--space-xl);
    background: rgba(30, 24, 19, 0.25);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 12px;
  }

  .work-project__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--paper);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }

  .work-project__tagline {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
  }

  .work-project__field {
    margin-bottom: var(--space-md);
  }

  .work-project__field:last-of-type {
    margin-bottom: 0;
  }

  .work-project__field-label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .work-project__field p {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
  }

  .work-project__links {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
  }

  .work-project__links a {
    color: var(--lamp);
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: text-decoration-color 0.3s ease;
  }

  .work-project__links a:hover {
    text-decoration-color: var(--lamp);
  }

  .work__empty {
    color: var(--faint);
    font-size: var(--text-sm);
  }

  @media (max-width: 480px) {
    .work {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
