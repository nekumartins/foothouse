---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Footer from '../../components/Footer.astro';
import { getProjects } from '../../lib/queries';
import { withGithubStars } from '../../lib/github';

const projects = await getProjects();
const projectsWithStars = await withGithubStars(projects);
---

<BaseLayout title="Work | Neku Akpotohwo" skyMode="receded">
  <div class="work">
    <header class="work__header">
      <h1>Work</h1>
      <p class="work__intro">
        A few things I have built. Not everything, just the ones worth showing.
      </p>
    </header>

    <div class="work__list">
      {projectsWithStars.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

    {projectsWithStars.length === 0 && (
      <p class="work__empty">Nothing here yet.</p>
    )}
  </div>

  <Footer />
</BaseLayout>

<style>
  .work {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .work__header {
    margin-bottom: var(--space-2xl);
  }

  .work__header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .work__intro {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .work__empty {
    color: var(--faint);
    font-size: var(--text-sm);
  }

  @media (max-width: 480px) {
    .work {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
