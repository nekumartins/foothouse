---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Work | Neku Akpotohwo" skyMode="receded">
  <div class="page-content">
    <h1>Work</h1>
    <p class="page-placeholder">Coming soon. Hand-picked projects will live here.</p>
  </div>
</BaseLayout>

<style>
  .page-content {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xl);
  }

  .page-placeholder {
    color: var(--muted);
  }
</style>
