---
import BaseLayout from '../layouts/BaseLayout.astro';
import LifeMap from '../components/LifeMap.astro';
import Footer from '../components/Footer.astro';
import { getPlaces } from '../lib/queries';

const places = await getPlaces();
---

<BaseLayout title="Map | Neku Akpotohwo" skyMode="receded">
  <div class="map-page">
    <header class="map-page__header">
      <h1>The Map</h1>
      <p class="map-page__intro">
        Places I have lived, travelled through, or just remember well. The pins are not exhaustive. They are the ones that stuck.
      </p>
    </header>
    <LifeMap places={places} />
  </div>

  <Footer />
</BaseLayout>

<style>
  .map-page {
    padding-top: calc(80px + var(--space-xl));
  }

  .map-page__header {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-xl) var(--space-xl);
  }

  .map-page__header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .map-page__intro {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .map-page__header {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
