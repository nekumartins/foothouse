---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import { getSeriesBySlug, getPostsBySeries } from '../../lib/queries';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: series } = await supabase.from('series').select('slug');
  return (series ?? []).map((s) => ({ params: { series: s.slug } }));
}

const { series: seriesSlug } = Astro.params;
const series = await getSeriesBySlug(seriesSlug!);

if (!series) {
  return Astro.redirect('/writing');
}

const posts = await getPostsBySeries(series.id);
---

<BaseLayout title={`${series.title} | Writing | Neku Akpotohwo`} skyMode="receded">
  <div class="series-page">
    <header class="series-page__header">
      <a href="/writing" class="series-page__back">&larr; Writing</a>
      <h1>{series.title}</h1>
      {series.blurb && <p class="series-page__blurb">{series.blurb}</p>}
    </header>

    <div class="series-page__posts">
      {posts.map((post) => (
        <PostRow post={post} seriesSlug={seriesSlug!} />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="series-page__empty">Nothing published here yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .series-page {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .series-page__header {
    margin-bottom: var(--space-2xl);
  }

  .series-page__back {
    font-size: var(--text-sm);
    color: var(--faint);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-lg);
    transition: color 0.3s ease;
  }

  .series-page__back:hover {
    color: var(--paper);
  }

  .series-page__header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .series-page__blurb {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .series-page__empty {
    color: var(--faint);
    font-size: var(--text-sm);
  }

  @media (max-width: 480px) {
    .series-page {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
