---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Footer from '../../../components/Footer.astro';
import { getPost, getAllSeriesPostPaths } from '../../../lib/queries';

export async function getStaticPaths() {
  const posts = await getAllSeriesPostPaths();
  return posts.map((p: any) => ({
    params: { series: p.series.slug, post: p.slug },
  }));
}

const { series: seriesSlug, post: postSlug } = Astro.params;
const result = await getPost(seriesSlug!, postSlug!);

if (!result || !result.body) {
  return Astro.redirect('/writing');
}

const { default: markdownit } = await import('markdown-it');
const md = markdownit({ html: true, typographer: false });
const rendered = md.render(result.body);

const dateStr = result.published_at
  ? new Date(result.published_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={`${result.title} | Neku Akpotohwo`} skyMode="receded">
  <article class="post">
    <header class="post__header">
      <a href={`/writing/${seriesSlug}`} class="post__back">&larr; {result.series.title}</a>
      <h1 class="post__title">{result.title}</h1>
      <div class="post__meta">
        {dateStr && <time>{dateStr}</time>}
        {result.reading_min && <span>{result.reading_min} min read</span>}
      </div>
    </header>

    <div class="post__body" set:html={rendered} />

    {result.medium_url && (
      <footer class="post__footer">
        <a href={result.medium_url} target="_blank" rel="noopener noreferrer" class="post__medium-link">
          Also on Medium &#8599;
        </a>
      </footer>
    )}
  </article>

  <Footer />
</BaseLayout>

<style>
  .post {
    max-width: 65ch;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .post__header { margin-bottom: var(--space-2xl); }

  .post__back {
    font-size: var(--text-sm);
    color: var(--faint);
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-lg);
    transition: color 0.3s ease;
  }

  .post__back:hover { color: var(--paper); }

  .post__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl));
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .post__meta {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--faint);
  }

  .post__body {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--paper);
  }

  .post__body :global(h1),
  .post__body :global(h2),
  .post__body :global(h3) {
    font-family: var(--font-display);
    font-weight: 400;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .post__body :global(h1) { display: none; }
  .post__body :global(h2) { font-size: var(--text-xl); }
  .post__body :global(h3) { font-size: var(--text-lg); }
  .post__body :global(p) { margin-bottom: var(--space-lg); }

  .post__body :global(blockquote) {
    border-left: 2px solid var(--line);
    padding-left: var(--space-lg);
    color: var(--muted);
    margin: var(--space-xl) 0;
    font-style: italic;
  }

  .post__body :global(code) {
    background: var(--raised);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post__body :global(pre) {
    background: var(--raised);
    padding: var(--space-lg);
    border-radius: 8px;
    overflow-x: auto;
    margin: var(--space-xl) 0;
  }

  .post__body :global(pre code) { background: none; padding: 0; }

  .post__body :global(a) {
    color: var(--lamp);
    text-decoration-color: rgba(224, 164, 88, 0.3);
  }

  .post__body :global(a:hover) { text-decoration-color: var(--lamp); }

  .post__footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }

  .post__medium-link {
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .post__medium-link:hover { color: var(--lamp); }

  @media (max-width: 480px) {
    .post {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
