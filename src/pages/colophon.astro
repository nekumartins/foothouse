---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/queries';

const settings = await getSiteSettings();
---

<BaseLayout title="About | Neku Akpotohwo" skyMode="receded">
  <div class="colophon">
    <header class="colophon__header">
      <h1>About</h1>
    </header>

    <section class="colophon__section">
      <p>
        I am Neku Akpotohwo. I study at Babcock University and help run GDG Babcock, where a thousand-something people learn to build together. I write, sometimes about philosophy, sometimes about engineering, mostly about the gap between the two.
      </p>
      <p>
        I like building things that feel alive. I like thinking about things that resist easy answers. I like being in rooms where people are making things they care about.
      </p>
    </section>
  </div>

  <Footer />
</BaseLayout>

<style>
  .colophon {
    max-width: 65ch;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .colophon__header {
    margin-bottom: var(--space-2xl);
  }

  .colophon__header h1 {
    font-size: var(--text-4xl);
  }

  .colophon__section {
    margin-bottom: var(--space-2xl);
  }

  .colophon__section p {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .colophon__section a {
    color: var(--lamp);
    text-decoration-color: rgba(224, 164, 88, 0.3);
  }

  .colophon__section a:hover {
    text-decoration-color: var(--lamp);
  }

  @media (max-width: 480px) {
    .colophon {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
