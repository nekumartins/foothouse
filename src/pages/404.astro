---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Lost | Neku Akpotohwo" skyMode="full">
  <div class="lost">
    <p class="lost__code" aria-hidden="true">404</p>
    <h1 class="lost__title">Nothing lives at this address.</h1>
    <p class="lost__line">The stars are still here, though. Make a wish.</p>
    <nav class="lost__paths" aria-label="Places that do exist">
      <a href="/">Home</a>
      <a href="/writing">Writing</a>
      <a href="/work">Work</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .lost {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 var(--space-xl);
  }

  .lost__code {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--faint);
    letter-spacing: 0.3em;
    margin-bottom: var(--space-md);
  }

  .lost__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl));
    font-weight: 300;
    color: var(--paper);
    margin-bottom: var(--space-md);
  }

  .lost__line {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--muted);
    margin-bottom: var(--space-xl);
  }

  .lost__paths {
    display: flex;
    gap: var(--space-lg);
  }

  .lost__paths a {
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: color 0.3s ease, text-decoration-color 0.3s ease;
  }

  .lost__paths a:hover {
    color: var(--lamp);
    text-decoration-color: var(--lamp);
  }
</style>
