---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getSiteSettings } from '../lib/queries';
import { youtubeEmbedUrl } from '../lib/video';

const settings = await getSiteSettings();
const socialSettings = { ...settings, contact_email: settings?.contact_email || 'akpotohwoo@gmail.com' };

const aboutVideo = settings?.about_video_url ? youtubeEmbedUrl(settings.about_video_url) : null;
---

<BaseLayout
  title="About | Neku Akpotohwo"
  description="Who Chukwuneku 'Neku' Akpotohwo is: AI-focused software engineer, organizer of GDG on Campus Babcock, writer."
  skyMode="receded"
>
  <div class="about">
    <header class="about__header">
      <h1>About</h1>
    </header>

    <section class="about__section">
      <p>I'm Chukwuneku Akpotohwo. Most people call me Neku. I'm a software engineer focused on AI, studying at Babcock University, and most of what I believe fits in one line: intelligence is built, not found.</p>
      <p>Since 2024 I've organized GDG on Campus Babcock, one of Nigeria's premier tech communities and the largest developer community on campus. We run summits, a publication, and a room where a thousand-something people teach each other things nobody assigned them.</p>
    </section>

    {aboutVideo && (
      <section class="about__video">
        <div class="video-embed">
          <iframe
            src={aboutVideo}
            title="Neku on GDG Babcock"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </section>
    )}

    <section class="about__section">
      <p>Off the clock I read cognitive psychology and take ideas apart until they stop reducing. I care about what grows minds, mine included, and what that looks like at the scale of a person, a community, a continent.</p>
    </section>

    <div class="about__reach">
      <SocialLinks settings={socialSettings} align="start" />
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .about {
    max-width: 65ch;
    margin: 0 auto;
    padding: calc(80px + var(--space-2xl)) var(--space-xl) var(--space-3xl);
  }

  .about__header {
    margin-bottom: var(--space-2xl);
  }

  .about__header h1 {
    font-size: var(--text-4xl);
  }

  .about__section {
    margin-bottom: var(--space-2xl);
  }

  .about__section h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-lg);
  }

  .about__section p {
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .about__section a {
    color: var(--lamp);
    text-decoration-color: rgba(224, 164, 88, 0.3);
  }

  .about__section a:hover {
    text-decoration-color: var(--lamp);
  }

  .about__video {
    margin-bottom: var(--space-2xl);
  }

  .about__reach {
    margin-top: var(--space-2xl);
  }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    background: var(--raised);
    margin-top: var(--space-lg);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 480px) {
    .about {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }
  }
</style>
