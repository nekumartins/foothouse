---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowCards from '../components/NowCards.astro';
import Services from '../components/Services.astro';
import ContactForm from '../components/ContactForm.astro';
import Testimonials from '../components/Testimonials.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostRow from '../components/PostRow.astro';
import Footer from '../components/Footer.astro';
import { getNow, getProjects, getSiteSettings, getInvolvements, getAllPublishedPosts, getExperience, getTestimonials } from '../lib/queries';
import { getSpotifyListening, getGitHubBuilding, getWorkItems } from '../lib/integrations';
import { withGithubStars } from '../lib/github';
import { youtubeEmbedUrl } from '../lib/video';
import { WA_DEFAULT, CONTACT_EMAIL } from '../lib/site';
import { SHOW_TESTIMONIALS } from '../lib/flags';

const [now, projects, settings, involvements, experience, testimonials] = await Promise.all([
  getNow(),
  getProjects(),
  getSiteSettings(),
  getInvolvements(),
  getExperience(),
  SHOW_TESTIMONIALS ? getTestimonials() : Promise.resolve([]),
]);

const [spotifyText, githubText] = await Promise.all([
  getSpotifyListening(),
  getGitHubBuilding(),
]);

if (now) {
  if (spotifyText) now.listening_text = spotifyText;
  if (githubText) now.building_text = githubText;
}

const projectsWithStars = await withGithubStars(projects);

const { items: workItems, fromGithub: workFromGithub } = await getWorkItems(projectsWithStars, settings);
const githubProfile = settings?.github || 'https://github.com/nekumartins';

// Writing teaser (replaces the duplicate-nav doors): surface the latest essays.
const latestPosts = (await getAllPublishedPosts()).slice(0, 2);

const bio = settings?.bio || 'Software engineer in Nigeria. I build websites, business automation, and AI systems.';
const craft = settings?.craft || "Right now I'm building Dysseo, a fitness app whose calorie engine adapts to your real rate of loss. Before it: a real-time AI voice debate coach running on Azure, and GDG on Campus Babcock, grown to 1,500+ members.";
const lookingFor = settings?.looking_for || 'Open to engineering roles and collaborations. The evidence is on the work page.';
const stack: string[] = settings?.stack?.length ? settings.stack : ['Python', 'FastAPI', 'PostgreSQL', 'Docker', 'Azure', 'TypeScript', 'React', 'Astro', 'Google Apps Script', 'Java/Spring Boot (learning)'];

const featured =
  involvements.find((i: any) => i.featured && i.story) ?? involvements[0] ?? null;
const otherInvolvements = featured
  ? involvements.filter((i: any) => i.id !== featured.id)
  : [];

const videoEmbed = settings?.featured_video_url ? youtubeEmbedUrl(settings.featured_video_url) : null;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chukwuneku Akpotohwo',
  alternateName: ['Neku Akpotohwo', 'Neku'],
  jobTitle: 'Software Engineer',
  description: 'Software engineer in Nigeria. Builds websites and automation for small businesses, and AI systems. Founded GDG on Campus Babcock.',
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Babcock University' },
  url: 'https://foothouse-nu.vercel.app',
  image: settings?.portrait_url || 'https://foothouse-nu.vercel.app/avatar.png',
  email: `mailto:${settings?.contact_email || CONTACT_EMAIL}`,
  sameAs: [
    settings?.github || 'https://github.com/nekumartins',
    settings?.linkedin || 'https://linkedin.com/in/nekumartins',
    settings?.twitter,
  ].filter(Boolean),
};
---

<BaseLayout title="Neku Akpotohwo – websites, automation, AI systems" skyMode="full">
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} is:inline />
  <div class="home">
  <div class="threshold">
    <section class="threshold__mood" aria-hidden="true"></section>

    <!-- Person -->
    <section class="threshold__person">
      <h1 class="threshold__name">Neku Akpotohwo</h1>
      <p class="threshold__tagline">{bio}</p>
      <p class="threshold__craft">{craft}</p>
      {lookingFor && <p class="threshold__looking">{lookingFor}</p>}
      {stack.length > 0 && (
        <ul class="threshold__stack" aria-label="Tech stack">
          {stack.map((tool: string) => <li>{tool}</li>)}
        </ul>
      )}
      <div class="threshold__actions">
        <nav class="threshold__reach" aria-label="Contact">
          <a class="threshold__contact" href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" data-goatcounter-click="whatsapp-hero">
            <svg class="threshold__contact-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.85.5 3.58 1.36 5.07L2 22l5.25-1.38a9.86 9.86 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2zm5.78 14.06c-.24.68-1.4 1.32-1.93 1.4-.53.08-1.06.31-3.54-.74-2.98-1.26-4.88-4.29-5.03-4.5-.14-.2-1.2-1.6-1.2-3.05 0-1.45.76-2.16 1.03-2.46.27-.3.59-.37.79-.37.2 0 .4 0 .57.01.18.01.43-.07.67.51.24.58.83 2.01.9 2.16.07.15.12.33.02.53-.1.2-.15.32-.29.5-.15.18-.31.4-.44.53-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.36 1.46.3.15.47.13.65-.08.18-.2.75-.87.95-1.17.2-.3.4-.24.67-.15.27.1 1.72.81 2.02.96.3.15.5.22.57.35.07.13.07.75-.17 1.43z"/></svg>
            Message me on WhatsApp
          </a>
          <a class="threshold__resume" href={`mailto:${CONTACT_EMAIL}?subject=Hi Neku`}>Email me</a>
        </nav>
        <p class="threshold__reply">I reply within a day.</p>
      </div>
      <hr class="threshold__divider" />
      <nav class="threshold__meta" aria-label="Jump to, and profiles">
        <a href="#services">For your business &#8595;</a>
        <a href="/work">Engineer? The work page has receipts &#8594;</a>
        {settings?.resume_url && (
          <a href={settings.resume_url} target="_blank" rel="noopener noreferrer">Résumé</a>
        )}
        <a href={settings?.github || 'https://github.com/nekumartins'} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={settings?.linkedin || 'https://linkedin.com/in/nekumartins'} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </nav>
    </section>

    <!-- Currently: slim presence strip, right under the hero -->
    <section class="threshold__presence">
      <NowCards now={now} />
    </section>

    <Services />

    {SHOW_TESTIMONIALS && testimonials.length > 0 && (
      <Testimonials testimonials={testimonials} />
    )}

    <!-- Selected work (hand-picked in CMS, or top GitHub repos as a fallback) -->
    {workItems.length > 0 && (
      <section class="threshold__projects">
        <h2 class="section-label">Selected work</h2>
        <div class="projects-grid">
          {workItems.map((project: any) => (
            <ProjectCard project={project} />
          ))}
        </div>
        {workFromGithub && (
          <a class="projects-more" href={githubProfile} target="_blank" rel="noopener noreferrer">
            More on GitHub &#8599;
          </a>
        )}
      </section>
    )}

    <!-- Experience: compact rows; the bullets live on /work -->
    {experience.length > 0 && (
      <section class="threshold__experience">
        <h2 class="section-label">Experience</h2>
        <div class="exp-list">
          {experience.map((job: any) => (
            <a
              class="exp-row"
              href={job.url || '/work'}
              {...(job.url ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="exp-row__main">
                <span class="exp-row__role">{job.role}</span>
                <span class="exp-row__company">
                  {job.company}
                  {job.url && (
                    <svg class="exp-row__arrow" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </span>
              </span>
              {job.period && <span class="exp-row__period">{job.period}</span>}
            </a>
          ))}
        </div>
        <a class="exp-more" href="/work">Full history &#8594;</a>
      </section>
    )}

    <!-- Community & involvement -->
    {featured && (
      <section class="threshold__community">
        <h2 class="section-label">Community</h2>
        <a href="/about" class="community-feature">
          <h3 class="community-feature__title">{featured.title}</h3>
          {featured.role && <span class="community-feature__role">{featured.role}</span>}
          {(featured.story || featured.blurb) && (
            <p class="community-feature__story">{featured.story || featured.blurb}</p>
          )}
        </a>
        {otherInvolvements.length > 0 && (
          <div class="involvement-list">
            {otherInvolvements.map((item: any) => (
              <div class="involvement-item">
                <div class="involvement-item__content">
                  <h3 class="involvement-item__title">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer" class="involvement-item__link">
                        {item.title}
                        <svg class="involvement-item__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    ) : item.title}
                  </h3>
                  {item.role && <span class="involvement-item__role">{item.role}</span>}
                  {item.blurb && <p class="involvement-item__blurb">{item.blurb}</p>}
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    <!-- Featured video -->
    {videoEmbed && (
      <section class="threshold__video">
        <div class="video-embed">
          <iframe src={videoEmbed} title="Featured video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
      </section>
    )}

    <!-- Writing teaser (the repurposed doors) -->
    {latestPosts.length > 0 && (
      <section class="threshold__writing">
        <h2 class="section-label">Writing</h2>
        <div class="writing-teaser">
          {latestPosts.map((post: any) => (
            <PostRow post={post} seriesSlug={post.series?.slug} />
          ))}
        </div>
        <a class="writing-teaser__more" href="/writing">More in Writing &#8594;</a>
      </section>
    )}
    <ContactForm />
  </div>

  <Footer settings={settings} />
  </div>
</BaseLayout>

<style>
  /* The sky shows behind the hero up top; by the time you scroll past it the page
     rests on solid warm-dark — one continuous interior through the footer, no seam. */
  .home {
    background: linear-gradient(
      to bottom,
      transparent 0,
      transparent 70vh,
      var(--bg) 110vh
    );
  }

  .threshold {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-xl);
  }

  .threshold__mood {
    height: clamp(96px, 18vh, 30vh);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .threshold__mood {
      height: 30vh;
    }
  }

  /* ── Person ── */

  /* Thin translucent glass, not a slab: fixed alpha, the ink token flips
     with the sky instead of the fill darkening to hold contrast. Stays
     readable — and stays glass — at noon and at midnight alike. */
  .threshold__person {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    text-align: left;
    max-width: var(--w-text);
    margin-bottom: var(--space-3xl);
    padding: clamp(var(--space-xl), 5vw, var(--space-2xl));
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid var(--glass-edge);
    border-radius: var(--r-lg);
    box-shadow: inset 0 1px 0 var(--glass-rim);
    transition: background-color 800ms ease, border-color 800ms ease;
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.2s;
  }

  .threshold__name {
    text-align: left;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 3.25rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-wrap: balance;
    max-width: 58ch;
    transition: color var(--t-med) ease;
  }

  .threshold__tagline {
    font-size: var(--text-lg);
    color: var(--ink);
    max-width: 58ch;
    line-height: 1.75;
    transition: color var(--t-med) ease;
  }

  .threshold__craft {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--ink-muted);
    max-width: 58ch;
    line-height: 1.7;
    text-wrap: pretty;
    transition: color var(--t-med) ease;
  }

  .threshold__looking {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--ink-muted);
    max-width: 58ch;
    line-height: 1.7;
    transition: color var(--t-med) ease;
  }

  .threshold__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: var(--space-sm);
  }

  .threshold__stack li {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    padding: 4px 12px;
    border: 1px solid var(--tint-edge);
    border-radius: var(--r-pill);
    background: var(--tint);
    white-space: nowrap;
    transition: color var(--t-med) ease, background-color var(--t-med) ease, border-color var(--t-med) ease;
  }

  .threshold__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .threshold__reach {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* WhatsApp is the page's primary action: flat vibrant fill, no drop
     shadow, no text-shadow, ever. Depth comes only from the material
     around it, not from this button. */
  .threshold__reach a.threshold__contact {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    color: var(--bg);
    background: var(--lamp);
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid var(--lamp);
    border-radius: var(--r-pill);
    font-weight: 500;
    transition: background-color var(--t-fast) var(--ease-out), transform var(--t-fast) var(--ease-out);
  }

  .threshold__reach a.threshold__contact:hover {
    background: color-mix(in srgb, var(--lamp) 88%, white);
    transform: translateY(-1px);
  }

  .threshold__reach a.threshold__contact:active {
    transform: translateY(1px);
  }

  .threshold__contact-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Email is the secondary chip: outline, a step below the primary. */
  .threshold__reach a.threshold__resume {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    color: var(--ink);
    text-decoration: none;
    padding: 5px 18px;
    border: 1px solid var(--glass-edge);
    border-radius: var(--r-pill);
    transition: background-color var(--t-fast) var(--ease-out), color var(--t-med) ease, border-color var(--t-med) ease;
  }

  .threshold__reach a.threshold__resume:hover {
    background: var(--tint);
  }

  .threshold__reply {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    transition: color var(--t-med) ease;
  }

  .threshold__divider {
    border: none;
    height: 1px;
    background: var(--tint-edge);
    width: 100%;
    transition: background-color var(--t-med) ease;
  }

  .threshold__meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
  }

  .threshold__meta a {
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--ink-accent) 40%, transparent);
    text-underline-offset: 0.15em;
    transition: text-decoration-color var(--t-fast) ease, color var(--t-fast) ease;
  }

  .threshold__meta a:hover {
    color: var(--ink-accent);
    text-decoration-color: var(--ink-accent);
  }

  /* ── Presence ── */

  .threshold__presence {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3xl);
    padding: var(--space-sm) var(--space-lg);
    background: var(--glass);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid var(--glass-edge);
    border-radius: var(--r-pill);
    box-shadow: inset 0 1px 0 var(--glass-rim);
    transition: background-color 800ms ease, border-color 800ms ease;
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.4s;
    width: 100%;
  }

  /* Collapse the spacing (and glass) this section reserves when the strip has nothing to show. */
  .threshold__presence:has(.now-strip[hidden]) {
    margin-bottom: 0;
    padding: 0;
    background: none;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* ── Section label ── */

  .section-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }

  /* ── Projects ── */

  .threshold__projects {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.6s;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
  }

  .projects-more {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .projects-more:hover {
    color: var(--lamp);
  }

  /* ── Experience (compact; bullets live on /work) ── */

  .threshold__experience {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.7s;
  }

  .exp-list {
    display: flex;
    flex-direction: column;
  }

  .exp-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition: border-color 0.3s ease;
  }

  .exp-row:first-child {
    border-top: 1px solid var(--line);
  }

  .exp-row:hover {
    border-color: rgba(224, 164, 88, 0.25);
  }

  .exp-row__main {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
    min-width: 0;
  }

  .exp-row__role {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--paper);
    transition: color 0.3s ease;
  }

  .exp-row:hover .exp-row__role {
    color: var(--lamp);
  }

  .exp-row__company {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .exp-row__period {
    font-size: var(--text-xs);
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .exp-row__arrow {
    color: var(--faint);
    margin-left: 2px;
    vertical-align: baseline;
    opacity: 0;
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .exp-row:hover .exp-row__arrow {
    opacity: 1;
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .exp-more {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .exp-more:hover {
    color: var(--lamp);
  }

  /* ── Community ── */

  .threshold__community {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.8s;
  }

  .community-feature {
    display: block;
    text-decoration: none;
    padding: var(--space-xl);
    background: rgba(30, 24, 19, 0.25);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 12px;
    margin-bottom: var(--space-lg);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .community-feature:hover {
    background: rgba(30, 24, 19, 0.45);
    border-color: rgba(236, 227, 214, 0.12);
  }

  .community-feature__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .community-feature:hover .community-feature__title {
    color: var(--lamp);
  }

  .community-feature__role {
    display: block;
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
  }

  .community-feature__story {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
  }

  .involvement-list {
    display: flex;
    flex-direction: column;
  }

  .involvement-item {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--line);
  }

  .involvement-item:first-child {
    border-top: 1px solid var(--line);
  }

  .involvement-item__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .involvement-item__link {
    color: var(--paper);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .involvement-item__link:hover {
    color: var(--lamp);
  }

  .involvement-item__arrow {
    color: var(--faint);
    flex-shrink: 0;
    opacity: 0;
    margin-left: var(--space-xs);
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
