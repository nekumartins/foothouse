---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowCards from '../components/NowCards.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostRow from '../components/PostRow.astro';
import Footer from '../components/Footer.astro';
import { getNow, getProjects, getSiteSettings, getInvolvements, getAllPublishedPosts, getExperience } from '../lib/queries';
import { getSpotifyListening, getGitHubBuilding, getWorkItems } from '../lib/integrations';
import { withGithubStars } from '../lib/github';
import { youtubeEmbedUrl } from '../lib/video';

const [now, projects, settings, involvements, experience] = await Promise.all([
  getNow(),
  getProjects(),
  getSiteSettings(),
  getInvolvements(),
  getExperience(),
]);

const [spotifyText, githubText] = await Promise.all([
  getSpotifyListening(),
  getGitHubBuilding(),
]);

if (now) {
  if (spotifyText) now.listening_text = spotifyText;
  if (githubText) now.building_text = githubText;
}

const projectsWithStars = await withGithubStars(projects);

const { items: workItems, fromGithub: workFromGithub } = await getWorkItems(projectsWithStars, settings);
const githubProfile = settings?.github || 'https://github.com/nekumartins';

// Writing teaser (replaces the duplicate-nav doors): surface the latest essays.
const latestPosts = (await getAllPublishedPosts()).slice(0, 2);

const bio = settings?.bio || "I'm Neku, somewhere between an engineer and someone who won't stop asking why.";
const craft = settings?.craft || "I build AI systems, and I built GDG on Campus Babcock into one of Nigeria's premier tech communities.";
// [VERIFY with owner] fallbacks — edit these in Sanity (Site Settings).
const lookingFor = settings?.looking_for || 'Open to engineering roles and collaborations where the hard part is teaching a system to think.';
const stack: string[] = settings?.stack?.length ? settings.stack : ['TypeScript', 'Python', 'React', 'Node.js', 'Astro'];

const featured =
  involvements.find((i: any) => i.featured && i.story) ?? involvements[0] ?? null;
const otherInvolvements = featured
  ? involvements.filter((i: any) => i.id !== featured.id)
  : [];

const videoEmbed = settings?.featured_video_url ? youtubeEmbedUrl(settings.featured_video_url) : null;

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Chukwuneku Akpotohwo',
  alternateName: ['Neku Akpotohwo', 'Neku'],
  jobTitle: 'Software Engineer',
  description: "AI-focused software engineer who founded and led GDG on Campus Babcock.",
  affiliation: { '@type': 'CollegeOrUniversity', name: 'Babcock University' },
  url: 'https://foothouse-nu.vercel.app',
  image: settings?.portrait_url || 'https://foothouse-nu.vercel.app/avatar.png',
  email: `mailto:${settings?.contact_email || 'akpotohwoo@gmail.com'}`,
  sameAs: [
    settings?.github || 'https://github.com/nekumartins',
    settings?.linkedin || 'https://linkedin.com/in/nekumartins',
    settings?.twitter,
  ].filter(Boolean),
};
---

<BaseLayout title="Neku Akpotohwo, software engineer" skyMode="full">
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} is:inline />
  <div class="home">
  <div class="threshold">
    <section class="threshold__mood" aria-hidden="true"></section>

    <!-- Person -->
    <section class="threshold__person">
      <h1 class="threshold__name">Neku Akpotohwo</h1>
      <p class="threshold__tagline">{bio}</p>
      <p class="threshold__craft">{craft}</p>
      {lookingFor && <p class="threshold__looking">{lookingFor}</p>}
      {stack.length > 0 && (
        <ul class="threshold__stack" aria-label="Tech stack">
          {stack.map((tool: string) => <li>{tool}</li>)}
        </ul>
      )}
      <nav class="threshold__reach" aria-label="Profiles and contact">
        <a class="threshold__contact" href={`mailto:${settings?.contact_email || 'akpotohwoo@gmail.com'}?subject=Hi Neku`}>Get in touch</a>
        {settings?.resume_url && (
          <a class="threshold__resume" href={settings.resume_url} target="_blank" rel="noopener noreferrer">Résumé</a>
        )}
        <a href={settings?.github || 'https://github.com/nekumartins'} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={settings?.linkedin || 'https://linkedin.com/in/nekumartins'} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </nav>
    </section>

    <!-- Currently: slim presence strip, right under the hero -->
    <section class="threshold__presence">
      <NowCards now={now} />
    </section>

    <!-- Selected work (hand-picked in CMS, or top GitHub repos as a fallback) -->
    {workItems.length > 0 && (
      <section class="threshold__projects">
        <h2 class="section-label">Selected work</h2>
        <div class="projects-grid">
          {workItems.map((project: any) => (
            <ProjectCard project={project} />
          ))}
        </div>
        {workFromGithub && (
          <a class="projects-more" href={githubProfile} target="_blank" rel="noopener noreferrer">
            More on GitHub &#8599;
          </a>
        )}
      </section>
    )}

    <!-- Experience: compact rows; the bullets live on /work -->
    {experience.length > 0 && (
      <section class="threshold__experience">
        <h2 class="section-label">Experience</h2>
        <div class="exp-list">
          {experience.map((job: any) => (
            <a
              class="exp-row"
              href={job.url || '/work'}
              {...(job.url ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="exp-row__main">
                <span class="exp-row__role">{job.role}</span>
                <span class="exp-row__company">
                  {job.company}
                  {job.url && (
                    <svg class="exp-row__arrow" width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </span>
              </span>
              {job.period && <span class="exp-row__period">{job.period}</span>}
            </a>
          ))}
        </div>
        <a class="exp-more" href="/work">Full history &#8594;</a>
      </section>
    )}

    <!-- Community & involvement -->
    {featured && (
      <section class="threshold__community">
        <h2 class="section-label">Community</h2>
        <a href="/about" class="community-feature">
          <h3 class="community-feature__title">{featured.title}</h3>
          {featured.role && <span class="community-feature__role">{featured.role}</span>}
          {(featured.story || featured.blurb) && (
            <p class="community-feature__story">{featured.story || featured.blurb}</p>
          )}
        </a>
        {otherInvolvements.length > 0 && (
          <div class="involvement-list">
            {otherInvolvements.map((item: any) => (
              <div class="involvement-item">
                <div class="involvement-item__content">
                  <h3 class="involvement-item__title">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer" class="involvement-item__link">
                        {item.title}
                        <svg class="involvement-item__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    ) : item.title}
                  </h3>
                  {item.role && <span class="involvement-item__role">{item.role}</span>}
                  {item.blurb && <p class="involvement-item__blurb">{item.blurb}</p>}
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    <!-- Featured video -->
    {videoEmbed && (
      <section class="threshold__video">
        <div class="video-embed">
          <iframe src={videoEmbed} title="Featured video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
      </section>
    )}

    <!-- Writing teaser (the repurposed doors) -->
    {latestPosts.length > 0 && (
      <section class="threshold__writing">
        <h2 class="section-label">Writing</h2>
        <div class="writing-teaser">
          {latestPosts.map((post: any) => (
            <PostRow post={post} seriesSlug={post.series?.slug} />
          ))}
        </div>
        <a class="writing-teaser__more" href="/writing">More in Writing &#8594;</a>
      </section>
    )}
  </div>

  <Footer settings={settings} />
  </div>
</BaseLayout>

<style>
  /* The sky shows behind the hero up top; by the time you scroll past it the page
     rests on solid warm-dark — one continuous interior through the footer, no seam. */
  .home {
    background: linear-gradient(
      to bottom,
      transparent 0,
      transparent 70vh,
      var(--bg) 110vh
    );
  }

  .threshold {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-xl);
  }

  .threshold__mood {
    height: 30vh;
    min-height: 180px;
    flex-shrink: 0;
  }

  /* ── Person ── */

  .threshold__person {
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.2s;
  }

  .threshold__name {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 300;
    color: var(--paper);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .threshold__tagline {
    font-size: var(--text-lg);
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .threshold__craft {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--paper);
    max-width: 480px;
    margin: var(--space-md) auto 0;
    line-height: 1.6;
  }

  .threshold__looking {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--muted);
    max-width: 480px;
    margin: var(--space-md) auto 0;
    line-height: 1.6;
  }

  .threshold__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    max-width: 480px;
    margin: var(--space-md) auto 0;
  }

  .threshold__stack li {
    font-size: var(--text-xs);
    color: var(--muted);
    padding: 3px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(30, 24, 19, 0.35);
    white-space: nowrap;
  }

  .threshold__reach {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    margin-top: var(--space-lg);
  }

  .threshold__reach a {
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: text-decoration-color 0.3s ease, color 0.3s ease;
  }

  .threshold__reach a:hover {
    color: var(--lamp);
    text-decoration-color: var(--lamp);
  }

  /* Get in touch is the page's primary action: filled, the strongest chip. */
  .threshold__reach a.threshold__contact {
    color: var(--bg);
    background: var(--lamp);
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid var(--lamp);
    border-radius: 999px;
    font-weight: 500;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  }

  .threshold__reach a.threshold__contact:hover {
    color: var(--bg);
    background: color-mix(in srgb, var(--lamp) 82%, white);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px -8px color-mix(in srgb, var(--lamp) 70%, transparent);
  }

  /* Résumé is the secondary chip: outline, a step below the primary. */
  .threshold__reach a.threshold__resume {
    color: var(--lamp);
    text-decoration: none;
    padding: 5px 14px;
    border: 1px solid color-mix(in srgb, var(--lamp) 45%, transparent);
    border-radius: 999px;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .threshold__reach a.threshold__resume:hover {
    background: color-mix(in srgb, var(--lamp) 14%, transparent);
    border-color: var(--lamp);
  }

  /* ── Presence ── */

  .threshold__presence {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.4s;
    width: 100%;
  }

  /* Collapse the spacing this section reserves when the strip has nothing to show. */
  .threshold__presence:has(.now-strip[hidden]) {
    margin-bottom: 0;
  }

  /* ── Section label ── */

  .section-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }

  /* ── Projects ── */

  .threshold__projects {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.6s;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
  }

  .projects-more {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .projects-more:hover {
    color: var(--lamp);
  }

  /* ── Experience (compact; bullets live on /work) ── */

  .threshold__experience {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.7s;
  }

  .exp-list {
    display: flex;
    flex-direction: column;
  }

  .exp-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition: border-color 0.3s ease;
  }

  .exp-row:first-child {
    border-top: 1px solid var(--line);
  }

  .exp-row:hover {
    border-color: rgba(224, 164, 88, 0.25);
  }

  .exp-row__main {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
    min-width: 0;
  }

  .exp-row__role {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--paper);
    transition: color 0.3s ease;
  }

  .exp-row:hover .exp-row__role {
    color: var(--lamp);
  }

  .exp-row__company {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .exp-row__period {
    font-size: var(--text-xs);
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .exp-row__arrow {
    color: var(--faint);
    margin-left: 2px;
    vertical-align: baseline;
    opacity: 0;
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .exp-row:hover .exp-row__arrow {
    opacity: 1;
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .exp-more {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .exp-more:hover {
    color: var(--lamp);
  }

  /* ── Community ── */

  .threshold__community {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.8s;
  }

  .community-feature {
    display: block;
    text-decoration: none;
    padding: var(--space-xl);
    background: rgba(30, 24, 19, 0.25);
    border: 1px solid rgba(236, 227, 214, 0.06);
    border-radius: 12px;
    margin-bottom: var(--space-lg);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .community-feature:hover {
    background: rgba(30, 24, 19, 0.45);
    border-color: rgba(236, 227, 214, 0.12);
  }

  .community-feature__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .community-feature:hover .community-feature__title {
    color: var(--lamp);
  }

  .community-feature__role {
    display: block;
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
  }

  .community-feature__story {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
  }

  .involvement-list {
    display: flex;
    flex-direction: column;
  }

  .involvement-item {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--line);
  }

  .involvement-item:first-child {
    border-top: 1px solid var(--line);
  }

  .involvement-item__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .involvement-item__link {
    color: var(--paper);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .involvement-item__link:hover {
    color: var(--lamp);
  }

  .involvement-item__arrow {
    color: var(--faint);
    flex-shrink: 0;
    opacity: 0;
    margin-left: var(--space-xs);
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .involvement-item__link:hover .involvement-item__arrow {
    opacity: 1;
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .involvement-item__role {
    display: block;
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-xs);
  }

  .involvement-item__blurb {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Video ── */

  .threshold__video {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1.0s;
  }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    background: var(--raised);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Writing teaser ── */

  .threshold__writing {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1.1s;
  }

  .writing-teaser {
    display: flex;
    flex-direction: column;
  }

  .writing-teaser__more {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .writing-teaser__more:hover {
    color: var(--lamp);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .threshold__person,
    .threshold__presence,
    .threshold__projects,
    .threshold__experience,
    .threshold__community,
    .threshold__video,
    .threshold__writing {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .threshold {
      padding: 0 var(--space-md);
    }

    .threshold__mood {
      height: 25vh;
      min-height: 140px;
    }

    .threshold__name {
      font-size: var(--text-3xl);
    }
  }
</style>
