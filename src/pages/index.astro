---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowCards from '../components/NowCards.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';
import { getNow, getProjects, getSiteSettings, getInvolvements } from '../lib/queries';
import { getSpotifyListening, getGitHubBuilding } from '../lib/integrations';

const [now, projects, settings, involvements] = await Promise.all([
  getNow(),
  getProjects(),
  getSiteSettings(),
  getInvolvements(),
]);

const [spotifyText, githubText] = await Promise.all([
  getSpotifyListening(),
  getGitHubBuilding(),
]);

if (now) {
  if (spotifyText) now.listening_text = spotifyText;
  if (githubText) now.building_text = githubText;
}

const projectsWithStars = await Promise.all(
  projects.map(async (project: any) => {
    if (!project.github_sync || !project.repo_url) return project;
    try {
      const match = project.repo_url.match(/github\.com\/([^/]+)\/([^/]+)/);
      if (!match) return project;
      const res = await fetch(`https://api.github.com/repos/${match[1]}/${match[2]}`, {
        headers: import.meta.env.GITHUB_TOKEN
          ? { Authorization: `token ${import.meta.env.GITHUB_TOKEN}` }
          : {},
      });
      if (!res.ok) return project;
      const data = await res.json();
      return { ...project, stars: data.stargazers_count };
    } catch {
      return project;
    }
  })
);

const bio = settings?.bio || "I'm Neku, somewhere between an engineer and someone who won't stop asking why.";

function youtubeEmbedUrl(url: string): string | null {
  try {
    const u = new URL(url);
    let videoId: string | null = null;
    if (u.hostname.includes('youtube.com')) videoId = u.searchParams.get('v');
    else if (u.hostname === 'youtu.be') videoId = u.pathname.slice(1);
    return videoId ? `https://www.youtube-nocookie.com/embed/${videoId}` : url;
  } catch { return null; }
}

const videoEmbed = settings?.featured_video_url ? youtubeEmbedUrl(settings.featured_video_url) : null;
---

<BaseLayout title="Neku Akpotohwo" skyMode="full">
  <div class="home">
  <div class="threshold">
    <section class="threshold__mood" aria-hidden="true"></section>

    <!-- Person -->
    <section class="threshold__person">
      <h1 class="threshold__name">Neku Akpotohwo</h1>
      <p class="threshold__tagline">{bio}</p>
    </section>

    <!-- Presence: now-cards -->
    <section class="threshold__presence">
      <NowCards now={now} />
    </section>

    <!-- Projects -->
    {projectsWithStars.length > 0 && (
      <section class="threshold__projects">
        <h2 class="section-label">Projects</h2>
        <div class="projects-grid">
          {projectsWithStars.map((project: any) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    )}

    <!-- Community & involvement -->
    {involvements.length > 0 && (
      <section class="threshold__community">
        <h2 class="section-label">Community</h2>
        <div class="involvement-list">
          {involvements.map((item: any) => (
            <div class="involvement-item">
              <div class="involvement-item__content">
                <h3 class="involvement-item__title">
                  {item.url ? (
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="involvement-item__link">
                      {item.title}
                      <svg class="involvement-item__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M3.5 10.5L10.5 3.5M10.5 3.5H5M10.5 3.5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ) : item.title}
                </h3>
                {item.role && <span class="involvement-item__role">{item.role}</span>}
                {item.blurb && <p class="involvement-item__blurb">{item.blurb}</p>}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Featured video -->
    {videoEmbed && (
      <section class="threshold__video">
        <div class="video-embed">
          <iframe
            src={videoEmbed}
            title="Featured video"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </section>
    )}

    <!-- Doors -->
    <section class="threshold__doors">
      <p class="threshold__invitation">
        Have a look around. There's <a href="/writing">writing</a>,
        a <a href="/map">map of where I've been</a>,
        and the <a href="/work">things I've made</a>.
      </p>
    </section>
  </div>

  <Footer />
  </div>
</BaseLayout>

<style>
  /* The sky shows behind the hero up top; by the time you scroll past it the page
     rests on solid warm-dark — one continuous interior through the footer, no seam. */
  .home {
    background: linear-gradient(
      to bottom,
      transparent 0,
      transparent 60vh,
      var(--bg) 95vh,
      var(--bg) 100%
    );
  }

  .threshold {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-xl);
  }

  .threshold__mood {
    height: 30vh;
    min-height: 180px;
    flex-shrink: 0;
  }

  /* ── Person ── */

  .threshold__person {
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.2s;
  }

  .threshold__name {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 300;
    color: var(--paper);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .threshold__tagline {
    font-size: var(--text-lg);
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Presence ── */

  .threshold__presence {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.5s;
    width: 100%;
  }

  /* ── Section label ── */

  .section-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }

  /* ── Projects ── */

  .threshold__projects {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.8s;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
  }

  /* ── Community ── */

  .threshold__community {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1s;
  }

  .involvement-list {
    display: flex;
    flex-direction: column;
  }

  .involvement-item {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--line);
  }

  .involvement-item:first-child {
    border-top: 1px solid var(--line);
  }

  .involvement-item__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--paper);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .involvement-item__link {
    color: var(--paper);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .involvement-item__link:hover {
    color: var(--lamp);
  }

  .involvement-item__arrow {
    color: var(--faint);
    flex-shrink: 0;
    opacity: 0;
    margin-left: var(--space-xs);
    transition: opacity 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .involvement-item__link:hover .involvement-item__arrow {
    opacity: 1;
    color: var(--lamp);
    transform: translate(1px, -1px);
  }

  .involvement-item__role {
    display: block;
    font-size: var(--text-xs);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-xs);
  }

  .involvement-item__blurb {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Video ── */

  .threshold__video {
    max-width: 560px;
    width: 100%;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1.1s;
  }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    background: var(--raised);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Doors ── */

  .threshold__doors {
    max-width: 480px;
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1.2s;
  }

  .threshold__invitation {
    font-size: var(--text-lg);
    color: var(--paper);
    line-height: 1.7;
  }

  .threshold__invitation a {
    color: var(--lamp);
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: text-decoration-color 0.3s ease;
  }

  .threshold__invitation a:hover {
    text-decoration-color: var(--lamp);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .threshold__person,
    .threshold__presence,
    .threshold__projects,
    .threshold__community,
    .threshold__video,
    .threshold__doors {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .threshold {
      padding: 0 var(--space-md);
    }

    .threshold__mood {
      height: 25vh;
      min-height: 140px;
    }

    .threshold__name {
      font-size: var(--text-3xl);
    }
  }
</style>
