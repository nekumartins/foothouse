---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowCards from '../components/NowCards.astro';
---

<BaseLayout title="Neku Akpotohwo" skyMode="full">
  <div class="threshold">
    <!-- (mood) the sky alone for a beat at top -->
    <section class="threshold__mood" aria-hidden="true"></section>

    <!-- (person) -->
    <section class="threshold__person">
      <h1 class="threshold__name">Neku Akpotohwo</h1>
      <p class="threshold__tagline">
        I'm Neku, somewhere between an engineer and someone who won't stop asking why.
      </p>
    </section>

    <!-- (presence) now-cards -->
    <section class="threshold__presence">
      <NowCards />
    </section>

    <!-- (quiet proof) community + featured project -->
    <section class="threshold__proof">
      <p class="threshold__community">
        Some of what I'm proudest of isn't code. I help run GDG Babcock, a thousand-something people learning to build together. We've thrown summits, started a publication, made things that outlast us.
      </p>
      <div class="threshold__featured">
        <p class="threshold__project-description">
          A sparring partner you argue with out loud, to get better at thinking on your feet.
        </p>
      </div>
    </section>

    <!-- (invitation) the doors -->
    <section class="threshold__doors">
      <p class="threshold__invitation">
        Have a look around. There's <a href="/writing">writing</a>,
        a <a href="/map">map of where I've been</a>,
        and the <a href="/work">things I've made</a>.
      </p>
    </section>
  </div>

  <!-- footer -->
  <footer class="threshold__footer">
    <p>
      Built this myself, late at night, mostly. The sky up there follows your time, not mine, so if it's dark where you are, that's just us in the same evening.
    </p>
  </footer>
</BaseLayout>

<style>
  .threshold {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 var(--space-xl);
  }

  .threshold__mood {
    height: 35vh;
    min-height: 200px;
    flex-shrink: 0;
  }

  .threshold__person {
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.2s;
  }

  .threshold__name {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 300;
    color: var(--paper);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .threshold__tagline {
    font-size: var(--text-lg);
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .threshold__presence {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.5s;
    width: 100%;
  }

  .threshold__proof {
    max-width: 560px;
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 0.8s;
  }

  .threshold__community {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .threshold__featured {
    padding: var(--space-lg) var(--space-xl);
    background: rgba(30, 24, 19, 0.3);
    border: 1px solid var(--line);
    border-radius: 12px;
  }

  .threshold__project-description {
    font-size: var(--text-sm);
    color: var(--paper);
    line-height: 1.6;
    font-style: italic;
    font-family: var(--font-display);
  }

  .threshold__doors {
    max-width: 480px;
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 1.2s ease both;
    animation-delay: 1.1s;
  }

  .threshold__invitation {
    font-size: var(--text-lg);
    color: var(--paper);
    line-height: 1.7;
  }

  .threshold__invitation a {
    color: var(--lamp);
    text-decoration: underline;
    text-decoration-color: rgba(224, 164, 88, 0.3);
    text-underline-offset: 0.15em;
    transition: text-decoration-color 0.3s ease;
  }

  .threshold__invitation a:hover {
    text-decoration-color: var(--lamp);
  }

  .threshold__footer {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl) var(--space-xl);
    border-top: 1px solid var(--line);
    max-width: 520px;
    margin: 0 auto;
  }

  .threshold__footer p {
    font-size: var(--text-sm);
    color: var(--faint);
    line-height: 1.7;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .threshold__person,
    .threshold__presence,
    .threshold__proof,
    .threshold__doors {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .threshold {
      padding: 0 var(--space-md);
    }

    .threshold__mood {
      height: 25vh;
      min-height: 140px;
    }

    .threshold__name {
      font-size: var(--text-3xl);
    }
  }
</style>
