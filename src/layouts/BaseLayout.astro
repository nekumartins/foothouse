---
import '../styles/global.css';
import Sky from '../components/Sky.astro';
import Starfield from '../components/Starfield.astro';
import TimeOverride from '../components/TimeOverride.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  /** Full presence on /, dimmed on inner pages */
  skyMode?: 'full' | 'receded';
}

const { title, skyMode = 'full' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Neku Akpotohwo. Somewhere between an engineer and someone who won't stop asking why." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/fraunces-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body data-sky-mode={skyMode}>
    <div class="sky-container" aria-hidden="true">
      <Sky />
      <Starfield />
    </div>

    <TimeOverride />
    <Nav />

    <main>
      <slot />
    </main>

    <script>
      import { initSky } from '../scripts/sky';
      initSky();
    </script>
  </body>
</html>

<style>
  .sky-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    transition: filter 1s ease, opacity 1s ease;
  }

  [data-sky-mode='receded'] .sky-container {
    filter: blur(6px) brightness(0.4) saturate(0.6);
    opacity: 0.5;
  }

  main {
    position: relative;
    z-index: 1;
  }
</style>
