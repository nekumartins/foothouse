---
import '../styles/global.css';
import Sky from '../components/Sky.astro';
import Starfield from '../components/Starfield.astro';
import CloudBed from '../components/CloudBed.astro';
import CelestialGrab from '../components/CelestialGrab.astro';
import TimeOverride from '../components/TimeOverride.astro';
import Nav from '../components/Nav.astro';
import { GOATCOUNTER_CODE } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  skyMode?: 'full' | 'receded';
  ogImage?: string;
}

const DEFAULT_DESCRIPTION =
  'Software engineer in Nigeria. Systems architect at an early-stage fintech; builder of Dysseo and a real-time AI debate coach. Led GDG on Campus Babcock to 1,500+ members; founded RADAR and Babcock 100.';

const { title, description = DEFAULT_DESCRIPTION, skyMode = 'full', ogImage = '/og.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-ink="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title="Neku Akpotohwo, writing" href={new URL('/rss.xml', Astro.site)} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/fraunces-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <script
      data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
      async
      src="//gc.zgo.at/count.js"
    ></script>
  </head>
  <body data-sky-mode={skyMode}>
    <div class="sky-container" aria-hidden="true">
      <Sky />
      <Starfield />
      <CloudBed />
    </div>

    <TimeOverride />
    <Nav />

    <main>
      <slot />
    </main>

    <CelestialGrab />

    <script>
      import { initSky } from '../scripts/sky';
      import { initSurface } from '../scripts/surface';
      // The listener registers before initSky() dispatches its first
      // sky-update, so the ink lands the correct value on first paint.
      initSurface();
      initSky();
    </script>
  </body>
</html>

<style>
  .sky-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    transition: filter 1s ease, opacity 1s ease;
  }

  [data-sky-mode='receded'] .sky-container {
    filter: blur(3px) brightness(0.55) saturate(0.7);
    opacity: 0.65;
  }

  main {
    position: relative;
    z-index: 1;
  }
</style>
